-- Lucide icon presets for notifications (asset ids that resolve under
-- standard Roblox executors; falls back gracefully when missing)
local NOTIF_ICONS = {
    info    = "rbxassetid://10723407389",  -- info
    success = "rbxassetid://10747373176",  -- check-circle
    warn    = "rbxassetid://10723434769",  -- alert-triangle
    error   = "rbxassetid://10723345766",  -- x-circle
    bell    = "rbxassetid://10723415903",  -- bell
}

function Aquafield:Notify(opts)
    opts = opts or {}
    local title    = opts.Title    or "Notification"
    local content  = opts.Content  or ""
    local duration = tonumber(opts.Duration) or 4
    local image    = opts.Image or NOTIF_ICONS.bell
    local th       = Aquafield.Theme

    if typeof(image) == "number" then
        image = "rbxassetid://" .. tostring(image)
    elseif type(image) == "string" and NOTIF_ICONS[image] then
        image = NOTIF_ICONS[image]
    end

    -- Card container (wrap so UIListLayout positions it cleanly while we
    -- animate the inner card horizontally for the slide-in effect)
    local wrap = new("Frame", {
        Size                   = UDim2.new(1, 0, 0, 78),
        BackgroundTransparency = 1,
        ClipsDescendants       = false,
        ZIndex                 = 50,
        Parent                 = NotifHolder,
    })

    local card = new("Frame", {
        Size                   = UDim2.new(1, 0, 1, 0),
        Position               = UDim2.new(1, 80, 0, 0),
        BackgroundColor3       = th.Sidebar,
        BackgroundTransparency = 0.02,
        BorderSizePixel        = 0,
        ZIndex                 = 51,
        Parent                 = wrap,
    })
    corner(card, 12)
    stroke(card, th.Border, 1, 0.3)
    themed(card, "Sidebar")

    -- Soft accent gradient overlay (does NOT cover content because its
    -- ZIndex stays under the labels)
    local glow = new("Frame", {
        Size                   = UDim2.new(1, 0, 1, 0),
        BackgroundColor3       = th.Accent,
        BackgroundTransparency = 0.88,
        BorderSizePixel        = 0,
        ZIndex                 = 51,
        Parent                 = card,
    })
    corner(glow, 12); themed(glow, "Accent")
    new("UIGradient", {
        Color        = ColorSequence.new(Color3.new(1,1,1), Color3.new(0,0,0)),
        Rotation     = 25,
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.4),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Parent = glow,
    })

    local accent = new("Frame", {
        Size             = UDim2.new(0, 3, 1, -16),
        Position         = UDim2.new(0, 8, 0, 8),
        BackgroundColor3 = th.Accent,
        BorderSizePixel  = 0,
        ZIndex           = 52,
        Parent           = card,
    })
    corner(accent, 2); themed(accent, "Accent")

