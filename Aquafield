                BackgroundColor3      = Color3.fromRGB(0, 0, 0),
                BackgroundTransparency = 0.92,
                BorderSizePixel       = 0,
                Parent                = overlay,
            })
        end
    end
    return overlay
end

-- Confetti burst at a position (used on toggle-on).
function Effects.Confetti(parent, x, y, color)
    if not Aquafield.EffectsEnabled then return end
    for i = 1, 14 do
        local p = Util.New("Frame", {
            AnchorPoint            = Vector2.new(0.5, 0.5),
            Position               = UDim2.fromOffset(x, y),
            Size                   = UDim2.fromOffset(4, 4),
            BackgroundColor3       = color,
            BackgroundTransparency = 0,
            BorderSizePixel        = 0,
            Rotation               = math.random(0, 360),
            ZIndex                 = 999,
            Parent                 = parent,
        })
        Util.Corner(p, 1)
        local angle = math.random() * math.pi * 2
        local dist  = 30 + math.random() * 40
        Util.Tween(p, 0.55, {
            Position               = UDim2.fromOffset(x + math.cos(angle) * dist, y + math.sin(angle) * dist),
            BackgroundTransparency = 1,
            Rotation               = p.Rotation + math.random(-180, 180),
        }, Enum.EasingStyle.Quad)
        task.delay(0.6, function() p:Destroy() end)
    end
end

-- Glitch flash (used on errors / theme switch).
function Effects.GlitchFlash(parent, color)
    if not Aquafield.EffectsEnabled then return end
    local flash = Util.New("Frame", {
        Size                   = UDim2.fromScale(1, 1),
        BackgroundColor3       = color or Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.6,
        BorderSizePixel        = 0,
        ZIndex                 = 200,
        Parent                 = parent,
    })
    Util.Tween(flash, 0.25, { BackgroundTransparency = 1 })
    task.delay(0.3, function() flash:Destroy() end)
end

-- Accent pulse: makes a stroke breathe.
function Effects.Pulse(stroke, fromT, toT, speed)
    local t = 0
    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not stroke.Parent then conn:Disconnect() return end
        t = t + dt * (speed or 2)
        stroke.Transparency = fromT + (math.sin(t) * 0.5 + 0.5) * (toT - fromT)
    end)
    return conn
end

-- Cursor trail: tiny dots that follow the mouse.
function Effects.CursorTrail(parent, color)
    if not Aquafield.EffectsEnabled or not Mouse then return end
    local container = Util.New("Frame", {
        Name                   = "CursorTrail",
        BackgroundTransparency = 1,
        Size                   = UDim2.fromScale(1, 1),
        ZIndex                 = 500,
        Parent                 = parent,
    })
    local dots, idx = {}, 1
    for i = 1, 12 do
        local d = Util.New("Frame", {
            AnchorPoint            = Vector2.new(0.5, 0.5),
            Size                   = UDim2.fromOffset(6 - i * 0.4, 6 - i * 0.4),
            BackgroundColor3       = color or Color3.fromRGB(120, 200, 255),
            BackgroundTransparency = 0.4 + i * 0.05,
            BorderSizePixel        = 0,
            ZIndex                 = 500,
            Parent                 = container,
        })
        Util.Corner(d, 999)
        dots[i] = d
    end
    local prev = {}
    for i = 1, #dots do prev[i] = Vector2.new(0, 0) end
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not container.Parent then conn:Disconnect() return end
        local mx, my = Mouse.X, Mouse.Y
        prev[idx] = Vector2.new(mx, my)
        for i = 1, #dots do
            local j = ((idx - i) % #dots) + 1
            local pos = prev[j]
            dots[i].Position = UDim2.fromOffset(pos.X, pos.Y)
        end
        idx = (idx % #dots) + 1
    end)
    return container
end


