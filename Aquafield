local IconGlyphs = {}

-- Build an X (close) icon out of two rotated Frames so it ALWAYS renders.
function IconGlyphs.Close(parent, color)
    local holder = Instance.new("Frame")
    holder.Name = "Icon_Close"
    holder.BackgroundTransparency = 1
    holder.Size = UDim2.fromScale(1, 1)
    holder.Parent = parent

    local function bar(rot)
        local b = Instance.new("Frame")
        b.AnchorPoint = Vector2.new(0.5, 0.5)
        b.Position = UDim2.fromScale(0.5, 0.5)
        b.Size = UDim2.new(0.7, 0, 0, 2)
        b.BackgroundColor3 = color or Color3.fromRGB(255, 255, 255)
        b.BorderSizePixel = 0
        b.Rotation = rot
        local c = Instance.new("UICorner", b); c.CornerRadius = UDim.new(1, 0)
        b.Parent = holder
        return b
    end
    bar(45); bar(-45)
    return holder
end

