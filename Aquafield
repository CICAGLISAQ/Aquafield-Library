UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if Aquafield.ToggleKeyEnabled and input.KeyCode == Aquafield.ToggleKey then
        Aquafield._visible = not Aquafield._visible
        for _, win in ipairs(Aquafield._windows) do
            if win._mainFrame then
                if Aquafield._visible then
                    win._mainFrame.Visible = true
                    tween(win._mainFrame, 0.3, {BackgroundTransparency = 0.15})
                else
                    tween(win._mainFrame, 0.2, {BackgroundTransparency = 1}, Enum.EasingStyle.Quad)
                    task.delay(0.2, function()
                        if not Aquafield._visible then
                            win._mainFrame.Visible = false
                        end
                    end)
                end
            end
        end
    end
end)

-- ============================================================================
-- CREATE BACKGROUND PARTICLES
-- ============================================================================
local function createParticles(parent, themeColors)
    local particleContainer = new("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 0,
        Parent = parent,
        ClipsDescendants = true,
    })
    
    local particles = {}
    for i = 1, 30 do
        local size = math.random(2, 6)
        local p = new("Frame", {
            Size = UDim2.new(0, size, 0, size),
            Position = UDim2.new(math.random() * 0.9 + 0.05, 0, math.random() * 0.9 + 0.05, 0),
            BackgroundColor3 = themeColors.Accent,
            BackgroundTransparency = 0.6 + math.random() * 0.3,
            ZIndex = 0,
            Parent = particleContainer,
        })
        corner(p, size)
        table.insert(particles, {
            frame = p,
            speedX = (math.random() - 0.5) * 0.3,
            speedY = (math.random() - 0.5) * 0.3,
            drift = math.random() * 0.5 + 0.1,
            baseTransparency = p.BackgroundTransparency,
        })
    end
    
    local connection
    connection = RunService.Heartbeat:Connect(function(dt)
        for _, p in ipairs(particles) do
            local pos = p.frame.Position
            local newX = pos.X.Scale + p.speedX * dt
            local newY = pos.Y.Scale + p.speedY * dt
            if newX < 0 or newX > 0.95 then p.speedX = -p.speedX; newX = math.clamp(newX, 0, 0.95) end
            if newY < 0 or newY > 0.95 then p.speedY = -p.speedY; newY = math.clamp(newY, 0, 0.95) end
            p.frame.Position = UDim2.new(newX, 0, newY, 0)
            p.frame.BackgroundTransparency = p.baseTransparency + math.sin(os.clock() * p.drift) * 0.15
        end
    end)
    
    return connection
end

