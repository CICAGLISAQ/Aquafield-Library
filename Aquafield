-- ============================
-- LIBRARY INIT
-- ============================

function ShadowField:Notify(notificationConfig)
    -- Global notification function (needs an active window)
    for _, win in ipairs(ActiveWindows) do
        if win.ScreenGui and win.ScreenGui.Parent then
            return ShadowField:ShowNotification(notificationConfig, win.ScreenGui)
        end
    end
end

function ShadowField:Destroy()
    for _, win in ipairs(ActiveWindows) do
        pcall(function() win.ScreenGui:Destroy() end)
    end
    for _, conn in ipairs(UIConnections) do
        pcall(conn.Disconnect, conn)
    end
    ActiveWindows = {}
    UIConnections = {}
end

-- Export the library (call it like loadstring()())
return ShadowField
