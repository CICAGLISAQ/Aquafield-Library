    hex = hex:gsub("#", "")
    if #hex == 3 then
        hex = hex:sub(1,1):rep(2) .. hex:sub(2,2):rep(2) .. hex:sub(3,3):rep(2)
    end
    local r = tonumber(hex:sub(1,2), 16) or 0
    local g = tonumber(hex:sub(3,4), 16) or 0
    local b = tonumber(hex:sub(5,6), 16) or 0
    return Color3.fromRGB(r, g, b)
end
function Aquafield.Color.toHex(c)
    return string.format("#%02X%02X%02X",
        math.floor(c.R*255+0.5),
        math.floor(c.G*255+0.5),
        math.floor(c.B*255+0.5))
end
function Aquafield.Color.lerp(a, b, t)  return lerpColor(a, b, t) end
function Aquafield.Color.darken(c, f)   return darken(c, f) end
function Aquafield.Color.lighten(c, f)  return lighten(c, f) end
function Aquafield.Color.complement(c)
    return Color3.new(1 - c.R, 1 - c.G, 1 - c.B)
end
function Aquafield.Color.greyscale(c)
    local g = (c.R + c.G + c.B) / 3; return Color3.new(g, g, g)
end

