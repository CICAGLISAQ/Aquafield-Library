local AQUAFIELD_PREFS_FOLDER = "Aquafield"
local AQUAFIELD_PREFS_FILE   = "Aquafield/_Preferences.json"

local function ensureAquafieldFolder()
    if makefolder and isfolder and not isfolder(AQUAFIELD_PREFS_FOLDER) then
        pcall(makefolder, AQUAFIELD_PREFS_FOLDER)
    end
end

local function saveAquafieldPrefs()
    if not writefile then return end
    pcall(function()
        ensureAquafieldFolder()
        local prefs = {
            theme     = Aquafield.ThemeName,
            keybind   = Aquafield.ToggleUIKeybind and Aquafield.ToggleUIKeybind.Name or "K",
            acrylic   = Aquafield.AcrylicStrength,
            notifSide = Aquafield.NotifSide,
        }
        writefile(AQUAFIELD_PREFS_FILE, HttpService:JSONEncode(prefs))
    end)
end

local function loadAquafieldPrefs()
    if not (readfile and isfile) then return end
    pcall(function()
        if not isfile(AQUAFIELD_PREFS_FILE) then return end
        local prefs = HttpService:JSONDecode(readfile(AQUAFIELD_PREFS_FILE))
        if type(prefs) ~= "table" then return end
        if prefs.theme     then Aquafield:SetTheme(prefs.theme) end
        if prefs.keybind   then Aquafield.ToggleUIKeybind = keyCodeFromName(prefs.keybind) end
        if prefs.acrylic   then Aquafield.AcrylicStrength = prefs.acrylic end
        if prefs.notifSide then positionNotifHolder(prefs.notifSide) end
    end)
end

Aquafield._SavePrefs = saveAquafieldPrefs
Aquafield._LoadPrefs = loadAquafieldPrefs

local function configPath(w)
    local folder = w.Cfg.FolderName
    if folder and #folder > 0 then
        return ("%s/%s.json"):format(folder, w.Cfg.FileName or "Config")
    end
    return ("Aquafield_%s.json"):format(w.Cfg.FileName or "Config")
end

local function saveConfig(w)
    saveAquafieldPrefs()
    if not (w and w.Cfg and w.Cfg.Enabled and writefile) then return end
    pcall(function()
        if w.Cfg.FolderName and #w.Cfg.FolderName > 0
           and makefolder and isfolder and not isfolder(w.Cfg.FolderName) then
            makefolder(w.Cfg.FolderName)
        end
        local data = {}
        for k, v in pairs(Aquafield.Flags) do
            local cv = v.CurrentValue
            if typeof(cv) == "Color3" then
                data[k] = { "Color3", cv.R, cv.G, cv.B }
            else
                data[k] = cv
            end
        end
        writefile(configPath(w), HttpService:JSONEncode(data))
    end)
end

local function loadConfigFor(w)
    loadAquafieldPrefs()
    if not (w and w.Cfg and w.Cfg.Enabled and readfile and isfile) then return end
    pcall(function()
        if not isfile(configPath(w)) then return end
        local data = HttpService:JSONDecode(readfile(configPath(w)))
        if type(data) ~= "table" then return end
        data._meta = nil
        for k, v in pairs(data) do
            local f = Aquafield.Flags[k]
            if f and f.Set then
                if type(v) == "table" and v[1] == "Color3" then
                    f:Set(Color3.new(v[2], v[3], v[4]))
                else
                    f:Set(v)
                end
            end
        end
    end)
end

function Aquafield:LoadConfiguration()
    local w = self._windows[#self._windows]
    if w then loadConfigFor(w) end
end

