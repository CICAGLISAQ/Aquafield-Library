function ShadowField:CreateTab(window, tabConfig)
    if not tabConfig or not tabConfig.Name then
        error("ShadowField: Tab requires a Name")
    end
    
    local theme = window.Theme
    local tabsList = window.TabsList
    local pagesContainer = window.PagesContainer
    
    -- Tab button
    local tabButton = self:Create("TextButton", {
        Name = tabConfig.Name,
        BackgroundColor3 = theme.Tab.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -10, 0, 34),
        Font = Enum.Font.Gotham,
        Text = "  " .. tabConfig.Name,
        TextColor3 = theme.Tab.TextColor,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
        Parent = tabsList,
    })
    
    local tabButtonCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = tabButton,
    })
    
    -- Page frame for this tab
    local page = self:Create("Frame", {
        Name = tabConfig.Name .. "_Page",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        Visible = false,
        Parent = pagesContainer,
    })
    
    -- Page sections container
    local sectionsContainer = self:Create("ScrollingFrame", {
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = Color3.fromRGB(40, 40, 50),
        ScrollingDirection = Enum.ScrollingDirection.Y,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Parent = page,
    })
    
    local sectionsLayout = self:Create("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = sectionsContainer,
    })
    
    local sectionsPadding = self:Create("UIPadding", {
        PaddingLeft = UDim.new(0, 12),
        PaddingRight = UDim.new(0, 12),
        PaddingTop = UDim.new(0, 8),
        PaddingBottom = UDim.new(0, 8),
        Parent = sectionsContainer,
    })
    
    -- Tab object
    local Tab = {
        Name = tabConfig.Name,
        Button = tabButton,
        Page = page,
        SectionsContainer = sectionsContainer,
        Sections = {},
        IsSelected = false,
        
        Select = function(self)
            -- Deselect all tabs in this window
            for _, otherTab in pairs(window.Tabs) do
                if otherTab ~= self then
                    otherTab.IsSelected = false
                    self:TweenObject(otherTab.Button, {
                        BackgroundColor3 = theme.Tab.BackgroundColor,
                        TextColor3 = theme.Tab.TextColor,
                    }, TweenInfo.new(0.15))
                    otherTab.Page.Visible = false
                end
            end
            
            self.IsSelected = true
            self:TweenObject(self.Button, {
                BackgroundColor3 = theme.Tab.SelectedColor,
                TextColor3 = theme.Tab.SelectedTextColor,
            }, TweenInfo.new(0.15))
            self.Page.Visible = true
        end,
        
        CreateSection = function(self, sectionConfig)
            return ShadowField:CreateSection(window, self, sectionConfig)
        end,
    }
    
    -- Tab button click
    tabButton.MouseEnter:Connect(function()
        if not Tab.IsSelected then
            self:TweenObject(tabButton, {
                BackgroundColor3 = theme.Tab.HoverColor,
            }, TweenInfo.new(0.15))
        end
    end)
    
    tabButton.MouseLeave:Connect(function()
        if not Tab.IsSelected then
            self:TweenObject(tabButton, {
                BackgroundColor3 = theme.Tab.BackgroundColor,
            }, TweenInfo.new(0.15))
        end
    end)
    
    tabButton.MouseButton1Click:Connect(function()
        Tab:Select()
    end)
    
    -- Store tab
    window.Tabs[tabConfig.Name] = Tab
    table.insert(window.Tabs, Tab)
    
    -- Auto-select first tab
    if #window.Tabs == 1 then
        Tab:Select()
    end
    
    return Tab
end

