function Aquafield.IsKeyDown(name)
    local k = Enum.KeyCode[name]
    return k and UserInputService:IsKeyDown(k) or false
end

function Aquafield.GetMousePosition()
    if Mouse then return Vector2.new(Mouse.X, Mouse.Y) end
    return Vector2.new()
end

function Aquafield.GetViewportSize()
    return Camera.ViewportSize
end

function Aquafield.GetActiveWindow()
    return Aquafield.Windows[1]
end

function Aquafield.HideAll()
    for _, w in ipairs(Aquafield.Windows) do
        if w.Main then w.Main.Visible = false end
    end
end

function Aquafield.ShowAll()
    for _, w in ipairs(Aquafield.Windows) do
        if w.Main then w.Main.Visible = true end
    end
end

function Aquafield.CountFlags()
    local n = 0
    for _ in pairs(Aquafield.Flags) do n = n + 1 end
    return n
end

function Aquafield.DumpFlags()
    local out = {}
    for k, v in pairs(Aquafield.Flags) do
        table.insert(out, tostring(k) .. " = " .. tostring(v))
    end
    table.sort(out)
    return table.concat(out, "\n")
end

function Aquafield.PrintFlags()
    print(Aquafield.DumpFlags())
end


