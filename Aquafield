        VerticalAlignment   = Enum.VerticalAlignment.Bottom,
        Padding             = UDim.new(0, 2),
        Parent              = container,
    })
    local strips = {}
    for i = 1, bars do
        local b = Util.New("Frame", {
            Size                   = UDim2.new(1 / bars, -2, 0.5, 0),
            BackgroundColor3       = theme.Accent,
            BackgroundTransparency = 0.2,
            BorderSizePixel        = 0,
            Parent                 = container,
        })
        Util.Corner(b, 2)
        strips[i] = { inst = b, phase = math.random() * math.pi * 2, freq = 1 + math.random() * 3 }
    end
    local t = 0
    RunService.Heartbeat:Connect(function(dt)
        if not shell.Parent then return end
        t = t + dt
        for _, s in ipairs(strips) do
            local h = 0.2 + 0.8 * ((math.sin(t * s.freq + s.phase) + 1) * 0.5)
            s.inst.Size = UDim2.new(1 / bars, -2, h, 0)
        end
    end)
    return shell
end

