    ----------------------------------------------------------------
    Main.Size = UDim2.fromOffset(0, 0)
    Main.BackgroundTransparency = 1
    Halo.ImageTransparency = 1
    spring(Main, 0.65, { Size = UDim2.fromOffset(620, 420), BackgroundTransparency = 0 })
    tween(Halo, 0.5, { ImageTransparency = 0.55 })

    table.insert(Aquafield.Windows, self)

    ----------------------------------------------------------------
    -- TAB API
    ----------------------------------------------------------------
    function self:CreateTab(name, icon)
        local tab = {}
        tab.Name = name
        tab.Window = self
        tab.Elements = {}

        local button = create("TextButton", {
            Name = "Tab_"..name,
            AutoButtonColor = false,
            BackgroundColor3 = theme.Surface2,
            BackgroundTransparency = 0.4,
            BorderSizePixel = 0,
            Size = UDim2.fromOffset(0, 30),
            AutomaticSize = Enum.AutomaticSize.X,
            Font = Enum.Font.GothamMedium,
            Text = "   "..name.."   ",
            TextSize = 13,
            TextColor3 = theme.SubText,
            Parent = TabBar,
            ZIndex = 4,
        })
        corner(button, 8)
        create("UIPadding", {
            PaddingLeft = UDim.new(0, 6), PaddingRight = UDim.new(0, 6),
            Parent = button,
        })

        local page = create("ScrollingFrame", {
            Name = "Page_"..name,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = UDim2.fromScale(1, 1),
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = theme.Accent,
            ScrollingDirection = Enum.ScrollingDirection.Y,
            Visible = false,
            Parent = Content,
            ZIndex = 2,
        })
        local pageLayout = create("UIListLayout", {
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = page,
        })
        create("UIPadding", {
            PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 8),
            PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4),
            Parent = page,
        })

        tab.Button = button
        tab.Page   = page

        button.MouseEnter:Connect(function()
            if self.ActiveTab ~= tab then
                tween(button, 0.15, { BackgroundTransparency = 0.15, TextColor3 = theme.Text })
            end
        end)
        button.MouseLeave:Connect(function()
            if self.ActiveTab ~= tab then
                tween(button, 0.15, { BackgroundTransparency = 0.4, TextColor3 = theme.SubText })
            end
        end)
        button.MouseButton1Click:Connect(function() self:SelectTab(tab) end)

        table.insert(self.Tabs, tab)
        if not self.ActiveTab then
            task.defer(function() self:SelectTab(tab) end)
        end

        -- ===== element factories =====
        local Elements = require_inline_elements(self, tab, page, theme)
        for k, v in pairs(Elements) do tab[k] = v end

        return tab
    end

    function self:SelectTab(tab)
        if self.ActiveTab == tab then return end
        for _, t in ipairs(self.Tabs) do
            t.Page.Visible = false
            tween(t.Button, 0.18, { BackgroundTransparency = 0.4, TextColor3 = theme.SubText })
        end
        tab.Page.Visible = true
        self.ActiveTab = tab
        tween(tab.Button, 0.2, { BackgroundTransparency = 0, TextColor3 = Color3.fromRGB(255,255,255) })
        task.defer(function()
            local absPos = tab.Button.AbsolutePosition
            local barPos = TabBar.AbsolutePosition
            local sz = tab.Button.AbsoluteSize
            spring(TabHighlight, 0.4, {
                Position = UDim2.fromOffset(absPos.X - barPos.X + TabBar.CanvasPosition.X, 4),
                Size = UDim2.fromOffset(sz.X, 30),
            })
        end)
        -- page fade-in
        for _, child in ipairs(tab.Page:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextButton") then
                child.BackgroundTransparency = 1
                tween(child, 0.3, { BackgroundTransparency = 0 })
            end
        end
    end

    -- inject Settings tab after user finishes adding their own
    task.defer(function()
        if not self._noSettings then self:_InjectSettings() end
    end)

    return self
end


--==============================================================
-- ELEMENT FACTORIES
--==============================================================
function require_inline_elements(window, tab, page, theme)
    local E = {}

    local function baseFrame(h)
        local f = create("Frame", {
            BackgroundColor3 = theme.Surface,
            BackgroundTransparency = 0.1,
            BorderSizePixel = 0,
            Size = UDim2.new(1, -8, 0, h or 38),
            Parent = page,
        })
        corner(f, 8)
        stroke(f, theme.Stroke, 1, 0.7)
        return f
    end

    local function ripple(parent, x, y)
        local r = create("Frame", {
            BackgroundColor3 = Color3.fromRGB(255,255,255),
            BackgroundTransparency = 0.6,
            BorderSizePixel = 0,
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromOffset(x, y),
            Size = UDim2.fromOffset(0, 0),
            Parent = parent,
            ZIndex = 20,
        })
        corner(r, 999)
        tween(r, 0.5, { Size = UDim2.fromOffset(300, 300), BackgroundTransparency = 1 })
        task.delay(0.55, function() r:Destroy() end)
    end

    --========================== SECTION ==========================
    function E:CreateSection(text)
        local lbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -8, 0, 22),
            Font = Enum.Font.GothamBold,
            Text = string.upper(text),
            TextSize = 12,
            TextColor3 = theme.Accent,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = page,
        })
        return lbl
    end

    --========================== LABEL ============================
    function E:CreateLabel(text)
        local f = baseFrame(32)
        local lbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -20, 1, 0),
            Position = UDim2.fromOffset(12, 0),
            Font = Enum.Font.Gotham,
            Text = text,
            TextSize = 13,
            TextColor3 = theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = f,
        })
        return {
            Set = function(_, t) lbl.Text = t end
        }
    end

    --========================== PARAGRAPH ========================
    function E:CreateParagraph(opts)
        opts = opts or {}
        local f = baseFrame(60)
        f.Size = UDim2.new(1, -8, 0, 60)
        f.AutomaticSize = Enum.AutomaticSize.Y
        create("UIPadding", {
            PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12),
            PaddingTop = UDim.new(0, 8), PaddingBottom = UDim.new(0, 8),
            Parent = f,
        })
        create("TextLabel", {
            BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 16),
            Font = Enum.Font.GothamBold, Text = opts.Title or "Paragraph",
            TextSize = 13, TextColor3 = theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left, Parent = f,
        })
        create("TextLabel", {
            BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, -20),
            Position = UDim2.fromOffset(0, 20),
            Font = Enum.Font.Gotham, Text = opts.Content or "",
            TextSize = 12, TextColor3 = theme.SubText, TextWrapped = true,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top, Parent = f,
        })
    end

    --========================== BUTTON ===========================
    function E:CreateButton(opts)
        opts = opts or {}
        local f = baseFrame(38)
        f.ClipsDescendants = true
        local btn = create("TextButton", {
            BackgroundTransparency = 1,
            Size = UDim2.fromScale(1,1),
            Font = Enum.Font.GothamMedium,
            Text = opts.Name or "Button",
            TextSize = 13,
            TextColor3 = theme.Text,
            Parent = f,
            ZIndex = 3,
        })
        local grad = create("UIGradient", {
            Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, theme.Surface),
                ColorSequenceKeypoint.new(1, theme.Surface2),
            },
            Rotation = 0,
            Parent = f,
        })
        btn.MouseEnter:Connect(function()
            tween(f, 0.2, { BackgroundColor3 = theme.Accent, BackgroundTransparency = 0.85 })
            tween(btn, 0.2, { TextColor3 = theme.AccentGlow })
        end)
        btn.MouseLeave:Connect(function()
            tween(f, 0.2, { BackgroundColor3 = theme.Surface, BackgroundTransparency = 0.1 })
            tween(btn, 0.2, { TextColor3 = theme.Text })
        end)
        btn.MouseButton1Click:Connect(function()
            local mp = UserInputService:GetMouseLocation()
            local rel = mp - f.AbsolutePosition
            ripple(f, rel.X, rel.Y)
            spring(f, 0.4, { Size = UDim2.new(1, -8, 0, 38) })
            f.Size = UDim2.new(1, -12, 0, 36)
            safeCall(opts.Callback)
        end)
        return { Set = function(_, t) btn.Text = t end }
    end

    --========================== TOGGLE ===========================
    function E:CreateToggle(opts)
        opts = opts or {}
        local f = baseFrame(38)
        local lbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.fromOffset(12, 0),
            Size = UDim2.new(1, -70, 1, 0),
            Font = Enum.Font.Gotham, Text = opts.Name or "Toggle",
            TextSize = 13, TextColor3 = theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left, Parent = f,
        })
        local switch = create("Frame", {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -12, 0.5, 0),
            Size = UDim2.fromOffset(38, 20),
            BackgroundColor3 = theme.Surface2,
            BorderSizePixel = 0,
            Parent = f,
        })
        corner(switch, 10)
        stroke(switch, theme.Stroke, 1, 0.4)
        local knob = create("Frame", {
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 2, 0.5, 0),
            Size = UDim2.fromOffset(16, 16),
            BackgroundColor3 = theme.SubText,
            BorderSizePixel = 0,
            Parent = switch,
        })
        corner(knob, 10)

        local state = opts.CurrentValue == true
        local function apply()
            if state then
                tween(switch, 0.2, { BackgroundColor3 = theme.Accent })
                tween(knob, 0.25, { Position = UDim2.new(1, -18, 0.5, 0),
                                    BackgroundColor3 = Color3.fromRGB(255,255,255) })
            else
                tween(switch, 0.2, { BackgroundColor3 = theme.Surface2 })
                tween(knob, 0.25, { Position = UDim2.new(0, 2, 0.5, 0),
                                    BackgroundColor3 = theme.SubText })
            end
        end
        apply()

        local hit = create("TextButton", {
            BackgroundTransparency = 1, Text = "", Size = UDim2.fromScale(1,1), Parent = f,
        })
        hit.MouseButton1Click:Connect(function()
            state = not state
            apply()
            safeCall(opts.Callback, state)
            if opts.Flag then
                Aquafield.Flags[opts.Flag] = { CurrentValue = state }
                Aquafield:SaveConfig(window.ConfigName)
            end
        end)

        if opts.Flag then
            Aquafield.Flags[opts.Flag] = { CurrentValue = state }
        end
        return {
            Set = function(_, v) state = v and true or false; apply()
                if opts.Flag then Aquafield.Flags[opts.Flag].CurrentValue = state end
            end,
            Get = function() return state end,
        }
    end

    --========================== SLIDER ===========================
    function E:CreateSlider(opts)
        opts = opts or {}
        local min = opts.Range and opts.Range[1] or 0
        local max = opts.Range and opts.Range[2] or 100
        local inc = opts.Increment or 1
        local val = opts.CurrentValue or min
        local f = baseFrame(54)
        local lbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.fromOffset(12, 4),
            Size = UDim2.new(1, -24, 0, 18),
            Font = Enum.Font.Gotham, Text = opts.Name or "Slider",
            TextSize = 13, TextColor3 = theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left, Parent = f,
        })
        local vlbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -60, 0, 4),
            Size = UDim2.fromOffset(48, 18),
            Font = Enum.Font.GothamBold, Text = tostring(val)..(opts.Suffix or ""),
            TextSize = 12, TextColor3 = theme.Accent,
            TextXAlignment = Enum.TextXAlignment.Right, Parent = f,
        })
        local bar = create("Frame", {
            Position = UDim2.new(0, 12, 1, -18),
            Size = UDim2.new(1, -24, 0, 6),
            BackgroundColor3 = theme.Surface2,
            BorderSizePixel = 0, Parent = f,
        })
        corner(bar, 3)
        local fill = create("Frame", {
            Size = UDim2.fromScale((val - min)/(max - min), 1),
            BackgroundColor3 = theme.Accent, BorderSizePixel = 0, Parent = bar,
        })
        corner(fill, 3)
        create("UIGradient", {
            Color = ColorSequence.new(theme.Accent, theme.AccentGlow),
            Parent = fill,
        })
        local knob = create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new((val-min)/(max-min), 0, 0.5, 0),
            Size = UDim2.fromOffset(12, 12),
            BackgroundColor3 = Color3.fromRGB(255,255,255),
            BorderSizePixel = 0, Parent = bar,
        })
        corner(knob, 6)

        local dragging = false
        local function setFromX(px)
            local rel = math.clamp((px - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            local raw = min + (max - min) * rel
            val = math.floor(raw / inc + 0.5) * inc
            val = math.clamp(val, min, max)
            local pct = (val - min) / (max - min)
            tween(fill, 0.1, { Size = UDim2.fromScale(pct, 1) })
            tween(knob, 0.1, { Position = UDim2.new(pct, 0, 0.5, 0) })
            vlbl.Text = tostring(val)..(opts.Suffix or "")
            safeCall(opts.Callback, val)
            if opts.Flag then
                Aquafield.Flags[opts.Flag] = { CurrentValue = val }
            end
        end
        bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                setFromX(input.Position.X)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                          or input.UserInputType == Enum.UserInputType.Touch) then
                setFromX(input.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                if dragging then Aquafield:SaveConfig(window.ConfigName) end
                dragging = false
            end
        end)

        if opts.Flag then Aquafield.Flags[opts.Flag] = { CurrentValue = val } end
        return {
            Set = function(_, v) setFromX(bar.AbsolutePosition.X + (v-min)/(max-min)*bar.AbsoluteSize.X) end,
            Get = function() return val end,
        }
    end

    --========================== DROPDOWN =========================
    function E:CreateDropdown(opts)
        opts = opts or {}
        local options = opts.Options or {}
        local current = opts.CurrentOption or options[1] or ""
        local open = false
        local f = baseFrame(38)
        f.ClipsDescendants = true

        local lbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.fromOffset(12, 0),
            Size = UDim2.new(0.5, 0, 0, 38),
            Font = Enum.Font.Gotham, Text = opts.Name or "Dropdown",
            TextSize = 13, TextColor3 = theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left, Parent = f,
        })
        local selected = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0.5, 0, 0, 0),
            Size = UDim2.new(0.5, -32, 0, 38),
            Font = Enum.Font.GothamMedium, Text = tostring(current),
            TextSize = 12, TextColor3 = theme.Accent,
            TextXAlignment = Enum.TextXAlignment.Right, Parent = f,
        })
        local arrow = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -24, 0, 0),
            Size = UDim2.fromOffset(20, 38),
            Font = Enum.Font.GothamBold, Text = "▾", TextSize = 14,
            TextColor3 = theme.SubText, Parent = f,
        })
        local list = create("Frame", {
            BackgroundTransparency = 1,
            Position = UDim2.fromOffset(0, 38),
            Size = UDim2.new(1, 0, 0, 0),
            Parent = f,
        })
        local listLayout = create("UIListLayout", {
            Padding = UDim.new(0, 2), Parent = list,
        })
        local optionBtns = {}
        local function rebuild()
            for _, c in ipairs(list:GetChildren()) do
                if c:IsA("TextButton") then c:Destroy() end
            end
            optionBtns = {}
            for _, opt in ipairs(options) do
                local b = create("TextButton", {
                    AutoButtonColor = false,
                    BackgroundColor3 = theme.Surface2,
                    BackgroundTransparency = 0.2, BorderSizePixel = 0,
                    Size = UDim2.new(1, -8, 0, 26),
                    Position = UDim2.fromOffset(4, 0),
                    Font = Enum.Font.Gotham, Text = "  "..tostring(opt),
                    TextSize = 12, TextColor3 = theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = list,
                })
                corner(b, 6)
                b.MouseEnter:Connect(function() tween(b, 0.1, { BackgroundColor3 = theme.Accent, BackgroundTransparency = 0.5 }) end)
                b.MouseLeave:Connect(function() tween(b, 0.1, { BackgroundColor3 = theme.Surface2, BackgroundTransparency = 0.2 }) end)
                b.MouseButton1Click:Connect(function()
                    current = opt; selected.Text = tostring(opt)
                    safeCall(opts.Callback, opt)
                    if opts.Flag then
                        Aquafield.Flags[opts.Flag] = { CurrentValue = opt }
                        Aquafield:SaveConfig(window.ConfigName)
                    end
                    open = false
                    tween(f, 0.25, { Size = UDim2.new(1, -8, 0, 38) })
                    tween(arrow, 0.2, { Rotation = 0 })
                end)
                table.insert(optionBtns, b)
            end
        end
        rebuild()

        local hit = create("TextButton", {
            BackgroundTransparency = 1, Text = "",
            Size = UDim2.new(1, 0, 0, 38), Parent = f, ZIndex = 5,
        })
        hit.MouseButton1Click:Connect(function()
            open = not open
            if open then
                tween(f, 0.25, { Size = UDim2.new(1, -8, 0, 38 + (#options * 28) + 4) })
                tween(arrow, 0.2, { Rotation = 180 })
            else
                tween(f, 0.25, { Size = UDim2.new(1, -8, 0, 38) })
                tween(arrow, 0.2, { Rotation = 0 })
            end
        end)

        if opts.Flag then Aquafield.Flags[opts.Flag] = { CurrentValue = current } end
        return {
            Set = function(_, v) current = v; selected.Text = tostring(v) end,
            Refresh = function(_, newOpts) options = newOpts; rebuild() end,
            Get = function() return current end,
        }
    end

    --========================== INPUT ============================
    function E:CreateInput(opts)
        opts = opts or {}
        local f = baseFrame(38)
        local lbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.fromOffset(12, 0),
            Size = UDim2.new(0.4, 0, 1, 0),
            Font = Enum.Font.Gotham, Text = opts.Name or "Input",
            TextSize = 13, TextColor3 = theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left, Parent = f,
        })
        local box = create("TextBox", {
            BackgroundColor3 = theme.Surface2,
            BorderSizePixel = 0,
            Position = UDim2.new(0.4, 0, 0.5, -12),
            Size = UDim2.new(0.6, -16, 0, 24),
            Font = Enum.Font.Gotham, PlaceholderText = opts.PlaceholderText or "",
            Text = opts.CurrentValue or "", TextSize = 12,
            TextColor3 = theme.Text, PlaceholderColor3 = theme.SubText,
            ClearTextOnFocus = opts.RemoveTextAfterFocusLost or false,
            Parent = f,
        })
        corner(box, 6)
        stroke(box, theme.Stroke, 1, 0.5)
        box.FocusLost:Connect(function(enter)
            safeCall(opts.Callback, box.Text, enter)
            if opts.Flag then
                Aquafield.Flags[opts.Flag] = { CurrentValue = box.Text }
                Aquafield:SaveConfig(window.ConfigName)
            end
        end)
        return { Set = function(_, t) box.Text = t end, Get = function() return box.Text end }
    end

    --========================== KEYBIND ==========================
    function E:CreateKeybind(opts)
        opts = opts or {}
        local key = opts.CurrentKeybind or "K"
        local capturing = false
        local f = baseFrame(38)
        local lbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.fromOffset(12, 0),
            Size = UDim2.new(1, -110, 1, 0),
            Font = Enum.Font.Gotham, Text = opts.Name or "Keybind",
            TextSize = 13, TextColor3 = theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left, Parent = f,
        })
        local btn = create("TextButton", {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -12, 0.5, 0),
            Size = UDim2.fromOffset(80, 26),
            BackgroundColor3 = theme.Surface2,
            BorderSizePixel = 0,
            Font = Enum.Font.GothamBold, Text = key,
            TextSize = 12, TextColor3 = theme.Accent,
            Parent = f, AutoButtonColor = false,
        })
        corner(btn, 6)
        stroke(btn, theme.Stroke, 1, 0.5)
        btn.MouseButton1Click:Connect(function()
            capturing = true
            btn.Text = "..."
        end)
        UserInputService.InputBegan:Connect(function(input, processed)
            if capturing and input.UserInputType == Enum.UserInputType.Keyboard then
                capturing = false
                key = input.KeyCode.Name
                btn.Text = key
                safeCall(opts.Callback, input.KeyCode)
                if opts.Flag then
                    Aquafield.Flags[opts.Flag] = { CurrentValue = key }
                    Aquafield:SaveConfig(window.ConfigName)
                end
            end
        end)
        return { Set = function(_, k) key = k; btn.Text = k end, Get = function() return key end }
    end

    return E
end

--==============================================================
-- GLOBAL CONFIG / KEYBIND API
--==============================================================
function Aquafield:SetToggleKeybind(k)
    if typeof(k) == "EnumItem" then
        Aquafield.ToggleKey = k
    elseif type(k) == "string" and Enum.KeyCode[k] then
        Aquafield.ToggleKey = Enum.KeyCode[k]
    end
    for _, w in ipairs(Aquafield.Windows) do
        Aquafield:SaveConfig(w.ConfigName)
    end
end

function Aquafield:SetTheme(name)
    if not Aquafield.Themes[name] then return end
    Aquafield.CurrentTheme = name
    -- Soft notice; theme fully applies on next CreateWindow.
end

--==============================================================
-- AUTO-INJECTED SETTINGS TAB
--==============================================================
function Aquafield:_InjectSettings()
    local t = self:CreateTab("Settings")
    t:CreateSection("Appearance")
    t:CreateDropdown({
        Name = "Theme",
        Options = Aquafield.ThemeOrder,
        CurrentOption = Aquafield.CurrentTheme,
        Flag = "_AquafieldTheme",
        Callback = function(opt)
            Aquafield:SetTheme(opt)
            Aquafield:SaveConfig(self.ConfigName)
        end,
    })
    t:CreateSection("Controls")
    t:CreateKeybind({
        Name = "Toggle UI",
        CurrentKeybind = Aquafield.ToggleKey.Name,
        Flag = "_AquafieldKeybind",
        Callback = function(k) Aquafield:SetToggleKeybind(k) end,
    })
    t:CreateButton({
        Name = "Hide UI",
        Callback = function() self:Hide() end,
    })
    t:CreateSection("About")
    t:CreateParagraph({
        Title = "Aquafield " .. Aquafield.Version,
        Content = "A modern, glass-morphic Roblox UI library. "
            .. "Press your toggle key to hide/show. Drag the floating "
            .. "icon when hidden to reposition, click it to restore.",
    })
end

