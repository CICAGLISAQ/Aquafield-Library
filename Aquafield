-- COMMAND PALETTE (Ctrl+P)  ::  fuzzy-jump to any registered command.
--------------------------------------------------------------------------------
local Palette = { _cmds = {}, _gui = nil, _open = false }

function Palette.Register(name, callback)
    table.insert(Palette._cmds, { name = name, callback = callback })
end

local function buildPalette()
    if Palette._gui then return Palette._gui end
    local theme = ActiveTheme()
    local gui = Util.New("ScreenGui", {
        Name           = "AquafieldPalette",
        ResetOnSpawn   = false,
        IgnoreGuiInset = true,
        DisplayOrder   = 99999,
    })
    Util.SafeParent(gui)

    local backdrop = Util.New("Frame", {
        Size                   = UDim2.fromScale(1, 1),
        BackgroundColor3       = Color3.new(0, 0, 0),
        BackgroundTransparency = 0.5,
        BorderSizePixel        = 0,
        Parent                 = gui,
    })

    local panel = Util.New("Frame", {
        AnchorPoint      = Vector2.new(0.5, 0),
        Position         = UDim2.new(0.5, 0, 0.2, 0),
        Size             = UDim2.fromOffset(420, 280),
        BackgroundColor3 = theme.Background,
        BorderSizePixel  = 0,
        Parent           = gui,
    })
    Util.Corner(panel, 12)
    Util.Stroke(panel, theme.Border, 1, 0.3)

    local search = Util.New("TextBox", {
        Position               = UDim2.new(0, 12, 0, 12),
        Size                   = UDim2.new(1, -24, 0, 32),
        BackgroundColor3       = theme.Sidebar,
        BorderSizePixel        = 0,
        Text                   = "",
        PlaceholderText        = "Type a command...",
        Font                   = Enum.Font.Gotham,
        TextSize               = 13,
        TextColor3             = theme.Text,
        PlaceholderColor3      = theme.SubText,
        ClearTextOnFocus       = false,
        Parent                 = panel,
    })
    Util.Corner(search, 6)
    Util.New("UIPadding", {
        PaddingLeft  = UDim.new(0, 10),
        PaddingRight = UDim.new(0, 10),
        Parent       = search,
    })

    local list = Util.New("ScrollingFrame", {
        Position               = UDim2.new(0, 12, 0, 52),
        Size                   = UDim2.new(1, -24, 1, -64),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        ScrollBarThickness     = 2,
        CanvasSize             = UDim2.new(),
        AutomaticCanvasSize    = Enum.AutomaticSize.Y,
        Parent                 = panel,
    })
    Util.New("UIListLayout", { Padding = UDim.new(0, 4), Parent = list })

    local function rebuild(query)
        for _, c in ipairs(list:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        query = (query or ""):lower()
        for _, cmd in ipairs(Palette._cmds) do
            if query == "" or cmd.name:lower():find(query, 1, true) then
                local row = Util.New("TextButton", {
                    Size                   = UDim2.new(1, 0, 0, 28),
                    BackgroundColor3       = theme.Element,
                    BackgroundTransparency = 0.2,
                    BorderSizePixel        = 0,
                    AutoButtonColor        = false,
                    Text                   = "  " .. cmd.name,
                    Font                   = Enum.Font.Gotham,
                    TextSize               = 12,
                    TextColor3             = theme.Text,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Parent                 = list,
                })
                Util.Corner(row, 6)
                row.MouseButton1Click:Connect(function()
                    Palette.Close()
                    pcall(cmd.callback)
                end)
            end
        end
    end
    rebuild("")
    search:GetPropertyChangedSignal("Text"):Connect(function() rebuild(search.Text) end)
    backdrop.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then Palette.Close() end
    end)

    Palette._gui    = gui
    Palette._search = search
    return gui
end

function Palette.Open()
    if Palette._open then return end
    buildPalette()
    Palette._gui.Enabled = true
    Palette._open = true
    Palette._search:CaptureFocus()
end

function Palette.Close()
    if not Palette._open then return end
    Palette._gui.Enabled = false
    Palette._open = false
end

function Palette.Toggle()
    if Palette._open then Palette.Close() else Palette.Open() end
end

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.P
       and (UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
         or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)) then
        Palette.Toggle()
    elseif input.KeyCode == Enum.KeyCode.Escape and Palette._open then
        Palette.Close()
    end
end)

Aquafield.Palette = Palette


