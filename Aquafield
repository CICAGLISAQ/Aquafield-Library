UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if UserInputService:GetFocusedTextBox() then return end
    local w = Aquafield.Windows[1]
    if not w then return end
    if input.KeyCode == Enum.KeyCode.F2 then
        Anim.Shake(w.Main, 10, 0.4)
    elseif input.KeyCode == Enum.KeyCode.F3 then
        local p = w.Main.AbsolutePosition
        local x = (Mouse and Mouse.X or 0) - p.X
        local y = (Mouse and Mouse.Y or 0) - p.Y
        Effects.Fireworks(w.Main, x, y, ActiveTheme().Accent)
    elseif input.KeyCode == Enum.KeyCode.F4 then
        local p = w.Main.AbsolutePosition
        local x = (Mouse and Mouse.X or 0) - p.X
        local y = (Mouse and Mouse.Y or 0) - p.Y
        Effects.Shockwave(w.Main, x, y, ActiveTheme().AccentGlow)
    end
end)


--------------------------------------------------------------------------------
-- SPRING SYSTEM  ::  full integrator for arbitrary GuiObject properties
--------------------------------------------------------------------------------
local Spring = {}
Spring.__index = Spring

function Spring.new(target, k, c)
    return setmetatable({
        x      = 0,
        v      = 0,
        target = target or 0,
        k      = k or 80,
        c      = c or 12,
    }, Spring)
end

function Spring:SetTarget(t) self.target = t end
function Spring:Step(dt)
    local a = -self.k * (self.x - self.target) - self.c * self.v
    self.v = self.v + a * dt
    self.x = self.x + self.v * dt
    return self.x
end

Aquafield.Spring = Spring

--------------------------------------------------------------------------------
-- VIEWPORT REFLOW  ::  reposition windows when the camera viewport changes
--------------------------------------------------------------------------------
Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
    local vp = Camera.ViewportSize
    for _, w in ipairs(Aquafield.Windows) do
        if w.Main and w.Main.Parent then
            local p   = w.Main.AbsolutePosition
            local s   = w.Main.AbsoluteSize
            local nx  = math.clamp(p.X, 0, vp.X - s.X)
            local ny  = math.clamp(p.Y, 0, vp.Y - s.Y)
            w.Main.Position = UDim2.fromOffset(nx + s.X * 0.5, ny + s.Y * 0.5)
        end
    end
end)

--------------------------------------------------------------------------------
-- DEEP TABLE COPY / MERGE  ::  used by config & theme registration
--------------------------------------------------------------------------------
local function deepCopy(t)
    if type(t) ~= "table" then return t end
    local out = {}
    for k, v in pairs(t) do
        out[k] = deepCopy(v)
    end
    return out
end
local function deepMerge(dst, src)
    for k, v in pairs(src) do
        if type(v) == "table" and type(dst[k]) == "table" then
            deepMerge(dst[k], v)
        else
            dst[k] = v
        end
    end
    return dst
end
Util.DeepCopy  = deepCopy
Util.DeepMerge = deepMerge

--------------------------------------------------------------------------------
-- FLAG OBSERVERS  ::  subscribe to changes on Aquafield.Flags[<key>]
--------------------------------------------------------------------------------
local FlagObservers = {}
function Aquafield:OnFlagChange(flag, cb)
    FlagObservers[flag] = FlagObservers[flag] or {}
    table.insert(FlagObservers[flag], cb)
end
function Aquafield:SetFlag(flag, value)
    self.Flags[flag] = value
    if FlagObservers[flag] then
        for _, cb in ipairs(FlagObservers[flag]) do pcall(cb, value) end
    end
end


