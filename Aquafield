        tween(Halo,  0.25, { ImageTransparency = 1 })
        task.delay(0.25, function()
            Main.Visible = false
            Halo.Visible = false
        end)
        Restore.Visible = true
        Restore.Size = UDim2.fromOffset(0, 0)
        spring(Restore, 0.5, { Size = UDim2.fromOffset(46, 46) })
    end
    function self:Show()
        if self.Visible then return end
        self.Visible = true
        Restore.Visible = false
        Main.Visible = true; Halo.Visible = true
        Main.Size = UDim2.fromOffset(0, 0)
        Main.BackgroundTransparency = 1
        Halo.ImageTransparency = 1
        spring(Main, 0.5, { Size = UDim2.fromOffset(620, 420), BackgroundTransparency = 0 })
        tween(Halo, 0.4, { ImageTransparency = 0.55 })
    end
    function self:Toggle()
        if self.Visible then self:Hide() else self:Show() end
    end
    function self:Minimize()
        self.Minimized = not self.Minimized
        if self.Minimized then
            self._restoreSize = Main.Size
            tween(Main, 0.3, { Size = UDim2.fromOffset(620, 42) })
        else
            tween(Main, 0.3, { Size = self._restoreSize or UDim2.fromOffset(620, 420) })
        end
    end
    function self:Destroy()
        tween(Main, 0.2, { Size = UDim2.fromOffset(0,0), BackgroundTransparency = 1 })
        tween(Halo, 0.2, { ImageTransparency = 1 })
        task.delay(0.25, function() ScreenGui:Destroy() end)
    end

