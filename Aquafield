        Parent                = parent,
    })

    local blobs = {}
    for i = 1, 4 do
        local b = Util.New("Frame", {
            Size                  = UDim2.fromOffset(360, 360),
            Position              = UDim2.fromScale(math.random(), math.random()),
            AnchorPoint           = Vector2.new(0.5, 0.5),
            BackgroundColor3      = i % 2 == 0 and theme.Gradient1 or theme.Gradient2,
            BackgroundTransparency = 0.75,
            BorderSizePixel       = 0,
            ZIndex                = 0,
            Parent                = container,
        })
        Util.Corner(b, 999)
        blobs[i] = { inst = b, seed = math.random() * 1000 }
    end

    local t = 0
    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not container.Parent then conn:Disconnect() return end
        t = t + dt * 0.15
        for i, b in ipairs(blobs) do
            local x = 0.5 + 0.4 * math.sin(t + b.seed + i)
            local y = 0.5 + 0.4 * math.cos(t * 0.8 + b.seed + i * 0.5)
            b.inst.Position = UDim2.fromScale(x, y)
        end
    end)
    return container
end

-- Holographic gradient border that drifts.
function Effects.HoloBorder(parent, theme)
    local stroke = Util.Stroke(parent, theme.Accent, 1, 0.2)
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   theme.AccentGlow),
        ColorSequenceKeypoint.new(0.5, theme.AccentSoft),
        ColorSequenceKeypoint.new(1,   theme.AccentGlow),
    })
    grad.Parent = stroke
    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not parent.Parent then conn:Disconnect() return end
        grad.Rotation = (grad.Rotation + dt * 40) % 360
    end)
    return stroke
end

-- Scanlines overlay (CRT vibe).
function Effects.Scanlines(parent)
    if not Aquafield.EffectsEnabled then return end
    local overlay = Util.New("Frame", {
        Name                  = "Scanlines",
        Size                  = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        ZIndex                = 50,
