-- CONFIGURATION SAVE / LOAD  ::  Rayfield-compatible shim
--------------------------------------------------------------------------------
local CONFIG_FOLDER = "Aquafield"
local CONFIG_FILE   = "config.json"
local saveQueue, saveScheduled = {}, false

local function trySave(path, body)
    if writefile then
        pcall(function()
            if makefolder and not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
            writefile(path, body)
        end)
    end
end

local function tryLoad(path)
    if readfile and isfile and isfile(path) then
        local ok, data = pcall(readfile, path)
        if ok then return data end
    end
end

function Aquafield:SaveConfiguration()
    if not writefile then return end
    local data = {}
    for k, v in pairs(self.Flags) do
        if typeof(v) == "Color3" then
            data[k] = { _t = "Color3", r = v.R, g = v.G, b = v.B }
        elseif typeof(v) == "boolean" or typeof(v) == "number" or typeof(v) == "string" then
            data[k] = v
        end
    end
    local body = HttpService:JSONEncode(data)
    trySave(CONFIG_FOLDER .. "/" .. CONFIG_FILE, body)
end

function Aquafield:LoadConfiguration()
    local raw = tryLoad(CONFIG_FOLDER .. "/" .. CONFIG_FILE)
    if not raw then return end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok or type(data) ~= "table" then return end
    for k, v in pairs(data) do
        if type(v) == "table" and v._t == "Color3" then
            self.Flags[k] = Color3.new(v.r, v.g, v.b)
        else
            self.Flags[k] = v
        end
    end
end

-- Debounced autosave.
RunService.Heartbeat:Connect(function()
    if saveScheduled then return end
    saveScheduled = true
    task.delay(2, function()
        Aquafield:SaveConfiguration()
        saveScheduled = false
    end)
end)


--------------------------------------------------------------------------------
-- EXTRA MATH HELPERS
--------------------------------------------------------------------------------
function Util.Lerp(a, b, t) return a + (b - a) * t end
function Util.InverseLerp(a, b, v) return (v - a) / (b - a) end
function Util.Remap(v, a1, b1, a2, b2)
    return a2 + (b2 - a2) * Util.InverseLerp(a1, b1, v)
end
function Util.SmoothStep(t)
    t = Util.Clamp(t, 0, 1)
    return t * t * (3 - 2 * t)
end
function Util.SmootherStep(t)
    t = Util.Clamp(t, 0, 1)
    return t * t * t * (t * (t * 6 - 15) + 10)
end
function Util.EaseOutCubic(t) return 1 - (1 - t)^3 end
function Util.EaseInCubic(t)  return t * t * t end
function Util.EaseInOutCubic(t)
    if t < 0.5 then return 4 * t * t * t end
    return 1 - ((-2 * t + 2)^3) / 2
end
function Util.EaseOutBack(t)
    local c1 = 1.70158
    local c3 = c1 + 1
    return 1 + c3 * (t - 1)^3 + c1 * (t - 1)^2
end
function Util.EaseOutElastic(t)
    local c4 = (2 * math.pi) / 3
    if t == 0 then return 0 end
    if t == 1 then return 1 end
    return 2^(-10 * t) * math.sin((t * 10 - 0.75) * c4) + 1
end
function Util.Wrap(v, lo, hi)
    local r = hi - lo
    if r == 0 then return lo end
    return ((v - lo) % r + r) % r + lo
end

--------------------------------------------------------------------------------
-- COLOR HELPERS
--------------------------------------------------------------------------------
function Util.Darken(c, amt)
    amt = amt or 0.1
    return Color3.new(
        math.max(0, c.R - amt),
        math.max(0, c.G - amt),
        math.max(0, c.B - amt)
    )
end
function Util.Lighten(c, amt)
    amt = amt or 0.1
    return Color3.new(
        math.min(1, c.R + amt),
        math.min(1, c.G + amt),
        math.min(1, c.B + amt)
    )
end
function Util.WithAlpha(c, a)
    -- Roblox Color3 has no alpha; helper bundles them into a {c, a} pair.
    return { Color = c, Alpha = a }
end
function Util.HSV(h, s, v) return Color3.fromHSV(h, s, v) end
function Util.RGB(r, g, b) return Color3.fromRGB(r, g, b) end

