        --   Walks every direct child of the active tab's page.
        --   For each child frame, finds its first TextLabel/TextButton
        --   descendant and matches the query (case-insensitive,
        --   substring).  Non-matching frames fade out + collapse.
        --   Section headers always stay visible.
        -- Collect ALL text from a component (label, sub-label, button,
        -- dropdown options) so a single query character lights up every
        -- matching element across the active tab.
        local function elementLabelText(frame)
            if not (frame:IsA("Frame") or frame:IsA("TextButton")) then return nil end
            local pieces = {}
            if frame:IsA("TextButton") and frame.Text and #frame.Text > 0 then
                pieces[#pieces + 1] = frame.Text
            end
            for _, d in ipairs(frame:GetDescendants()) do
                if (d:IsA("TextLabel") or d:IsA("TextBox") or d:IsA("TextButton"))
                and d.Text and #d.Text > 0 then
                    pieces[#pieces + 1] = d.Text
                end
            end
            if #pieces == 0 then return nil end
            return table.concat(pieces, " ")
        end

        local activeTab  -- shared upvalue: also assigned inside Window:CreateTab
        local function runSearch(query)
            query = tostring(query or ""):lower():gsub("^%s+", ""):gsub("%s+$", "")
            local page
            if activeTab then page = activeTab.Page end
            if not page then return end
            for _, child in ipairs(page:GetChildren()) do
                if child:IsA("Frame") or child:IsA("TextButton") then
                    if #query == 0 then
                        child.Visible = true
                    else
                        local txt = elementLabelText(child)
                        child.Visible = (txt ~= nil)
                            and (txt:lower():find(query, 1, true) ~= nil)
                    end
                end
            end
        end

