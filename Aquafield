        ------------------------------------------------------------
        function Tab:CreateSlider(o)
            local th = Aquafield.Theme
            local rng = o.Range or {0, 100}
            local min, max = rng[1], rng[2]
            local inc = o.Increment or 1
            local val = o.CurrentValue or min
            local f = baseElement(48)
            local lbl = new("TextLabel", {
                Text = o.Name or "Slider", Font = Enum.Font.GothamMedium, TextSize = 13,
                TextColor3 = th.Text, BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0, 4), Size = UDim2.new(1, -20, 0, 18),
                TextXAlignment = Enum.TextXAlignment.Left, Parent = f,
            })
            themed(lbl, "Text", "text")
            local valLbl = new("TextLabel", {
                Text = tostring(val) .. (o.Suffix or ""),
                Font = Enum.Font.GothamBold, TextSize = 12,
                TextColor3 = th.Accent, BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0, 4), Size = UDim2.new(1, -20, 0, 18),
                TextXAlignment = Enum.TextXAlignment.Right, Parent = f,
            })
            themed(valLbl, "Accent", "text")
            local bar = new("Frame", {
                Position = UDim2.new(0, 10, 1, -14),
                Size = UDim2.new(1, -20, 0, 6),
                BackgroundColor3 = th.Border, BorderSizePixel = 0, Parent = f,
            })
            corner(bar, 3)
            local fill = new("Frame", { Size = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = th.Accent, BorderSizePixel = 0, Parent = bar })
            corner(fill, 3); themed(fill, "Accent")

            local api = { CurrentValue = val }
            local function set(v, fire)
                v = math.clamp(v, min, max)
                v = math.floor(v / inc + 0.5) * inc
                val = v; api.CurrentValue = v
                fill.Size = UDim2.new((v - min) / math.max(max - min, 1e-6), 0, 1, 0)
                valLbl.Text = tostring(v) .. (o.Suffix or "")
                if fire and o.Callback then pcall(o.Callback, v) end
            end
            function api:Set(v) set(v, true) end
            set(val, false)
            if o.Callback then pcall(o.Callback, val) end

            local dragging = false
            bar.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1
                or i.UserInputType == Enum.UserInputType.Touch then dragging = true end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1
                or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
                              or i.UserInputType == Enum.UserInputType.Touch) then
                    local rel = (i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
                    rel = math.clamp(rel, 0, 1)
                    set(min + rel * (max - min), true)
                end
            end)

            if o.Flag then Aquafield.Flags[o.Flag] = api end
            return api
        end

