function ShadowField:CreateToggle(window, section, toggleConfig)
    local theme = window.Theme
    local elemTheme = theme.Element
    
    local toggleState = false
    
    -- Load saved state
    if window.SavedData and toggleConfig.Name then
        local saved = window.SavedData[toggleConfig.Name]
        if saved ~= nil then
            toggleState = saved
        end
    end
    
    local toggleFrame = self:Create("Frame", {
        BackgroundColor3 = elemTheme.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 36),
        Parent = section.ElementsContainer,
    })
    
    local toggleCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = toggleFrame,
    })
    
    -- Label
    local label = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        Font = Enum.Font.Gotham,
        Text = toggleConfig.Name or "Toggle",
        TextColor3 = elemTheme.TextColor,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = toggleFrame,
    })
    
    -- Toggle background (the pill)
    local toggleBg = self:Create("Frame", {
        BackgroundColor3 = toggleState and elemTheme.ToggleOn or elemTheme.ToggleOff,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 42, 0, 22),
        Position = UDim2.new(1, -52, 0.5, -11),
        Parent = toggleFrame,
    })
    
    local toggleBgCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 11),
        Parent = toggleBg,
    })
    
    -- Toggle knob
    local toggleKnob = self:Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        Size = UDim2.new(0, 18, 0, 18),
        Position = UDim2.new(0, toggleState and 22 or 2, 0.5, -9),
        Parent = toggleBg,
    })
    
    local toggleKnobCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 9),
        Parent = toggleKnob,
    })
    
    -- Info tooltip
    if toggleConfig.Info then
        local infoIcon = self:Create("ImageLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 14, 0, 14),
            Position = UDim2.new(0, label.TextBounds.X + 16, 0.5, -7),
            Image = "rbxassetid://6031094678",
            ImageColor3 = elemTheme.SubTextColor,
            ImageTransparency = 0.5,
            Parent = toggleFrame,
        })
    end
    
    local function SetToggleState(newState, triggerCallback)
        toggleState = newState
        
        self:TweenObject(toggleBg, {
            BackgroundColor3 = newState and elemTheme.ToggleOn or elemTheme.ToggleOff,
        }, TweenInfo.new(0.2))
        
        self:TweenObject(toggleKnob, {
            Position = UDim2.new(0, newState and 22 or 2, 0.5, -9),
        }, TweenInfo.new(0.2))
        
        -- Save configuration
        if toggleConfig.Name and window.ConfigSave.Enabled then
            window.SavedData[toggleConfig.Name] = newState
            ShadowField:SaveConfiguration(
                window.ConfigSave.FolderName,
                window.ConfigSave.FileName,
                window.SavedData
            )
        end
        
        if triggerCallback ~= false and toggleConfig.Callback then
            pcall(toggleConfig.Callback, newState)
        end
    end
    
    -- Click toggle
    toggleFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            SetToggleState(not toggleState, true)
        end
    end)
    
    -- Hover effect
    toggleFrame.MouseEnter:Connect(function()
        self:TweenObject(toggleFrame, {
            BackgroundColor3 = elemTheme.HoverColor,
        }, TweenInfo.new(0.15))
    end)
    toggleFrame.MouseLeave:Connect(function()
        self:TweenObject(toggleFrame, {
            BackgroundColor3 = elemTheme.BackgroundColor,
        }, TweenInfo.new(0.15))
    end)
    
    section.UpdateSize()
    
    -- Trigger initial callback if default is on
    if toggleState and toggleConfig.Callback then
        task.spawn(toggleConfig.Callback, true)
    end
    
    return {
        Frame = toggleFrame,
        ToggleBg = toggleBg,
        ToggleKnob = toggleKnob,
        Label = label,
        
        Set = function(self, state, trigger)
            SetToggleState(state, trigger)
        end,
        
        Get = function(self)
            return toggleState
        end,
        
        SetCallback = function(self, cb)
            toggleConfig.Callback = cb
        end,
        
        Destroy = function(self)
            toggleFrame:Destroy()
            section.UpdateSize()
        end,
    }
end

