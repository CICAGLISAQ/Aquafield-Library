                if gpe then return end
                if i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode.Name == key then
                    if o.Callback then pcall(o.Callback) end
                end
            end)

            local api = { CurrentKeybind = key }
            function api:Set(k) key = k; btn.Text = k; api.CurrentKeybind = k end
            api.CurrentValue = key
            if o.Flag then Aquafield.Flags[o.Flag] = api end
            return api
        end

