-- Mini sparkline chart (no external deps, just frames).
function ExtraComponents.Sparkline(page, name, data)
    data = data or {}
    local theme = ActiveTheme()
    local shell = Util.New("Frame", {
        Size                   = UDim2.new(1, 0, 0, 70),
        BackgroundColor3       = theme.Element,
        BackgroundTransparency = 0.05,
        BorderSizePixel        = 0,
        Parent                 = page,
    })
    Util.Corner(shell, 8)
    Util.Stroke(shell, theme.Border, 1, 0.5)
    Util.New("TextLabel", {
        Position               = UDim2.new(0, 12, 0, 4),
        Size                   = UDim2.new(1, -24, 0, 16),
        BackgroundTransparency = 1,
        Text                   = name or "",
        Font                   = Enum.Font.GothamMedium,
        TextSize               = 11,
        TextColor3             = theme.SubText,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = shell,
    })
    local plot = Util.New("Frame", {
        Position               = UDim2.new(0, 12, 0, 22),
        Size                   = UDim2.new(1, -24, 0, 42),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        Parent                 = shell,
    })
    local function redraw(arr)
        for _, c in ipairs(plot:GetChildren()) do c:Destroy() end
        if #arr == 0 then return end
        local minV, maxV = math.huge, -math.huge
        for _, v in ipairs(arr) do
            if v < minV then minV = v end
            if v > maxV then maxV = v end
        end
        if minV == maxV then maxV = minV + 1 end
        local stepW = 1 / math.max(#arr - 1, 1)
        for i = 1, #arr do
            local x  = (i - 1) * stepW
            local y  = 1 - (arr[i] - minV) / (maxV - minV)
            local bar = Util.New("Frame", {
                AnchorPoint            = Vector2.new(0.5, 1),
                Position               = UDim2.fromScale(x, 1),
                Size                   = UDim2.new(stepW, -1, 1 - y, 0),
                BackgroundColor3       = theme.Accent,
                BackgroundTransparency = 0.2,
                BorderSizePixel        = 0,
                Parent                 = plot,
            })
            Util.Corner(bar, 2)
        end
    end
    redraw(data)
    return {
        Update = function(_, arr) redraw(arr) end,
        Push   = function(_, v) table.insert(data, v); if #data > 32 then table.remove(data, 1) end; redraw(data) end,
    }
end

