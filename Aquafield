            TextYAlignment         = Enum.TextYAlignment.Top,
            ZIndex                 = 0,
            Parent                 = container,
        })
        columns[i] = col
    end
    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not container.Parent then conn:Disconnect() return end
        for _, c in ipairs(columns) do
            c.y = c.y + c.speed * dt
            if c.y > 1.1 then
                c.y = -0.1
                c.label.Text = string.char(math.random(33, 126))
            end
            c.label.Position = UDim2.fromScale(c.x, c.y)
        end
    end)
end

-- Starfield: tiny twinkling pinpricks.
function Effects.Starfield(parent, count, color)
    if not Aquafield.EffectsEnabled then return end
    count = count or 60
    local container = Util.New("Frame", {
        Name                   = "Starfield",
        BackgroundTransparency = 1,
        Size                   = UDim2.fromScale(1, 1),
        ClipsDescendants       = true,
        ZIndex                 = 0,
        Parent                 = parent,
    })
    local stars = {}
    for i = 1, count do
        local s = Util.New("Frame", {
            Position               = UDim2.fromScale(math.random(), math.random()),
            Size                   = UDim2.fromOffset(2, 2),
            BackgroundColor3       = color or Color3.fromRGB(255, 255, 255),
            BackgroundTransparency = math.random() * 0.6,
            BorderSizePixel        = 0,
            ZIndex                 = 0,
            Parent                 = container,
        })
        Util.Corner(s, 999)
        stars[i] = { inst = s, phase = math.random() * math.pi * 2, freq = 1 + math.random() * 3 }
    end
    local t = 0
    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not container.Parent then conn:Disconnect() return end
        t = t + dt
        for _, s in ipairs(stars) do
            local a = 0.3 + 0.5 * (math.sin(t * s.freq + s.phase) * 0.5 + 0.5)
            s.inst.BackgroundTransparency = 1 - a
        end
    end)
end

-- Lightning bolt across a region. Single flash.
function Effects.Lightning(parent, color)
    if not Aquafield.EffectsEnabled then return end
    local container = Util.New("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.fromScale(1, 1),
        ZIndex                 = 90,
        Parent                 = parent,
    })
    local segments = 12
    local px, py = 0.5, 0
    for i = 1, segments do
        local nx = px + (math.random() - 0.5) * 0.2
        local ny = py + 1 / segments
        local dx, dy = nx - px, ny - py
        local len = math.sqrt(dx * dx + dy * dy)
        local rot = math.deg(math.atan2(dy, dx))
        local seg = Util.New("Frame", {
            AnchorPoint            = Vector2.new(0, 0.5),
            Position               = UDim2.fromScale(px, py),
            Size                   = UDim2.new(len, 0, 0, 2),
            BackgroundColor3       = color or Color3.fromRGB(180, 220, 255),
            BackgroundTransparency = 0,
            BorderSizePixel        = 0,
            Rotation               = rot,
            ZIndex                 = 90,
            Parent                 = container,
        })
        Util.Tween(seg, 0.4, { BackgroundTransparency = 1 })
        px, py = nx, ny
    end
    task.delay(0.45, function() container:Destroy() end)
end

-- Fireworks burst at a position.
function Effects.Fireworks(parent, x, y, color)
    if not Aquafield.EffectsEnabled then return end
    for i = 1, 28 do
        local p = Util.New("Frame", {
            AnchorPoint            = Vector2.new(0.5, 0.5),
            Position               = UDim2.fromOffset(x, y),
            Size                   = UDim2.fromOffset(3, 3),
            BackgroundColor3       = color,
            BorderSizePixel        = 0,
            ZIndex                 = 999,
            Parent                 = parent,
        })
        Util.Corner(p, 999)
        local angle = (i / 28) * math.pi * 2
        local dist  = 50 + math.random() * 40
        Util.Tween(p, 0.7, {
            Position               = UDim2.fromOffset(x + math.cos(angle) * dist, y + math.sin(angle) * dist),
            BackgroundTransparency = 1,
            Size                   = UDim2.fromOffset(1, 1),
        }, Enum.EasingStyle.Quart)
        task.delay(0.75, function() p:Destroy() end)
    end
end

-- Ripple grid: a grid of dots that pulses outward from a point.
function Effects.RippleGrid(parent, cx, cy, color)
    if not Aquafield.EffectsEnabled then return end
    local container = Util.New("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.fromScale(1, 1),
        ZIndex                 = 1,
        Parent                 = parent,
    })
    local cols, rows = 16, 10
    local sx = parent.AbsoluteSize.X / cols
    local sy = parent.AbsoluteSize.Y / rows
    for r = 1, rows do
        for c = 1, cols do
            local px = (c - 0.5) * sx
            local py = (r - 0.5) * sy
            local d  = math.sqrt((px - cx)^2 + (py - cy)^2)
            local dot = Util.New("Frame", {
                AnchorPoint            = Vector2.new(0.5, 0.5),
                Position               = UDim2.fromOffset(px, py),
                Size                   = UDim2.fromOffset(2, 2),
                BackgroundColor3       = color,
                BackgroundTransparency = 0.5,
                BorderSizePixel        = 0,
                ZIndex                 = 1,
                Parent                 = container,
            })
            Util.Corner(dot, 999)
            task.delay(d / 600, function()
                Util.Tween(dot, 0.3, { Size = UDim2.fromOffset(6, 6), BackgroundTransparency = 0 })
                task.delay(0.3, function()
                    Util.Tween(dot, 0.4, { Size = UDim2.fromOffset(2, 2), BackgroundTransparency = 1 })
                end)
            end)
        end
    end
    task.delay(2, function() container:Destroy() end)
end

-- Shockwave ring expanding from a point.
function Effects.Shockwave(parent, x, y, color)
    if not Aquafield.EffectsEnabled then return end
    local ring = Util.New("Frame", {
        AnchorPoint            = Vector2.new(0.5, 0.5),
        Position               = UDim2.fromOffset(x, y),
        Size                   = UDim2.fromOffset(8, 8),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        ZIndex                 = 200,
        Parent                 = parent,
    })
    Util.Corner(ring, 999)
    local stroke = Util.Stroke(ring, color, 2, 0)
    Util.Tween(ring, 0.6, { Size = UDim2.fromOffset(180, 180) }, Enum.EasingStyle.Quad)
    Util.Tween(stroke, 0.6, { Transparency = 1, Thickness = 0 })
    task.delay(0.7, function() ring:Destroy() end)
end

-- Chromatic aberration on a frame (splits into RGB ghosts).
function Effects.ChromaticGhost(parent)
    if not Aquafield.EffectsEnabled then return end
    local function ghost(color, offset)
        local g = Util.New("Frame", {
