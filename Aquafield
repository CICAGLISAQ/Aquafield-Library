function ShadowField:CreateKeybind(window, section, keybindConfig)
    local theme = window.Theme
    local elemTheme = theme.Element
    local kbTheme = theme.Keybind
    
    local currentKey = keybindConfig.Default or Enum.KeyCode[window.UIKeybind] or Enum.KeyCode.K
    local isListening = false
    
    -- Load saved
    if window.SavedData and keybindConfig.Name then
        local saved = window.SavedData[keybindConfig.Name]
        if saved then
            currentKey = Enum.KeyCode[saved] or currentKey
        end
    end
    
    local kbFrame = self:Create("Frame", {
        BackgroundColor3 = elemTheme.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 36),
        Parent = section.ElementsContainer,
    })
    
    local kbCorner = self:Create("UICorner", {CornerRadius = UDim.new(0, 6), Parent = kbFrame})
    
    local label = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -80, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        Font = Enum.Font.Gotham,
        Text = keybindConfig.Name or "Keybind",
        TextColor3 = elemTheme.TextColor,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = kbFrame,
    })
    
    local keyButton = self:Create("TextButton", {
        BackgroundColor3 = kbTheme.KeyColor,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 60, 0, 26),
        Position = UDim2.new(1, -68, 0.5, -13),
        Font = Enum.Font.GothamSemibold,
        Text = ShadowField:GetKeyName({KeyCode = currentKey}),
        TextColor3 = kbTheme.TextColor,
        TextSize = 13,
        AutoButtonColor = false,
        Parent = kbFrame,
    })
    
    local keyCorner = self:Create("UICorner", {CornerRadius = UDim.new(0, 6), Parent = keyButton})
    
    keyButton.MouseButton1Click:Connect(function()
        isListening = true
        keyButton.Text = "..."
        keyButton.BackgroundColor3 = theme.Window.AccentColor
    end)
    
    local listenConnection
    listenConnection = UserInputService.InputBegan:Connect(function(input, gpe)
        if not isListening then return end
        if gpe then return end
        if input.UserInputType == Enum.UserInputType.Keyboard then
            isListening = false
            currentKey = input.KeyCode
            keyButton.Text = ShadowField:GetKeyName({KeyCode = currentKey})
            keyButton.BackgroundColor3 = kbTheme.KeyColor
            
            if keybindConfig.Name and window.ConfigSave.Enabled then
                window.SavedData[keybindConfig.Name] = tostring(currentKey):gsub("Enum.KeyCode.", "")
                ShadowField:SaveConfiguration(window.ConfigSave.FolderName, window.ConfigSave.FileName, window.SavedData)
            end
            
            if keybindConfig.Callback then
                pcall(keybindConfig.Callback, currentKey)
            end
        end
    end)
    
    kbFrame.MouseEnter:Connect(function()
        self:TweenObject(kbFrame, {BackgroundColor3 = elemTheme.HoverColor}, TweenInfo.new(0.15))
    end)
    kbFrame.MouseLeave:Connect(function()
        self:TweenObject(kbFrame, {BackgroundColor3 = elemTheme.BackgroundColor}, TweenInfo.new(0.15))
    end)
    
    section.UpdateSize()
    
    return {
        Frame = kbFrame,
        Set = function(self, key) 
            currentKey = key
            keyButton.Text = ShadowField:GetKeyName({KeyCode = key})
        end,
        Get = function(self) return currentKey end,
        SetCallback = function(self, cb) keybindConfig.Callback = cb end,
        Destroy = function(self) kbFrame:Destroy() listenConnection:Disconnect() section.UpdateSize() end,
    }
end

