        function Tab:CreateColorPicker(o)
            local th = Aquafield.Theme
            local color = o.Color or Color3.fromRGB(255, 255, 255)
            local open = false
            local f = baseElement(36)
            f.ClipsDescendants = true
            local lbl = new("TextLabel", {
                Text = o.Name or "Color", Font = Enum.Font.GothamMedium, TextSize = 13,
                TextColor3 = th.Text, BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0, 0), Size = UDim2.new(1, -50, 0, 36),
                TextXAlignment = Enum.TextXAlignment.Left, Parent = f,
            })
            themed(lbl, "Text", "text")
            local swatch = new("TextButton", {
                Text = "", BackgroundColor3 = color,
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -10, 0, 8),
                Size = UDim2.new(0, 30, 0, 20),
                AutoButtonColor = false, Parent = f,
            })
            corner(swatch, 4); stroke(swatch, th.Border, 1, 0.4)

            local panel = new("Frame", {
                Position = UDim2.new(0, 10, 0, 44),
                Size = UDim2.new(1, -20, 0, 80),
                BackgroundTransparency = 1, Parent = f,
            })
            local function sliderRow(name, y, getter)
                local row = new("Frame", {
                    Position = UDim2.new(0, 0, 0, y),
                    Size = UDim2.new(1, 0, 0, 22),
                    BackgroundTransparency = 1, Parent = panel,
                })
                new("TextLabel", { Text = name, Font = Enum.Font.GothamBold, TextSize = 11,
                    TextColor3 = th.SubText, BackgroundTransparency = 1,
                    Size = UDim2.new(0, 14, 1, 0), Parent = row })
                local bar = new("Frame", {
                    Position = UDim2.new(0, 20, 0.5, -3),
                    Size = UDim2.new(1, -20, 0, 6),
                    BackgroundColor3 = th.Border, BorderSizePixel = 0, Parent = row,
                })
                corner(bar, 3)
                local fill = new("Frame", {
                    Size = UDim2.new(getter(), 0, 1, 0),
                    BackgroundColor3 =
                        name == "R" and Color3.fromRGB(255,80,80) or
                        name == "G" and Color3.fromRGB(80,220,120) or
                                         Color3.fromRGB(80,160,255),
                    BorderSizePixel = 0, Parent = bar,
                })
                corner(fill, 3)
                return bar, fill
            end

            local rBar, rFill = sliderRow("R",  0, function() return color.R end)
            local gBar, gFill = sliderRow("G", 28, function() return color.G end)
            local bBar, bFill = sliderRow("B", 56, function() return color.B end)

            local api = { CurrentValue = color }
            local function update()
                swatch.BackgroundColor3 = color
                rFill.Size = UDim2.new(color.R, 0, 1, 0)
                gFill.Size = UDim2.new(color.G, 0, 1, 0)
                bFill.Size = UDim2.new(color.B, 0, 1, 0)
                api.CurrentValue = color
                if o.Callback then pcall(o.Callback, color) end
            end

            local function bind(bar, channel)
                local drag = false
                bar.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch then drag = true end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch then drag = false end
                end)
                UserInputService.InputChanged:Connect(function(i)
                    if drag and (i.UserInputType == Enum.UserInputType.MouseMovement
                              or i.UserInputType == Enum.UserInputType.Touch) then
                        local rel = math.clamp((i.Position.X - bar.AbsolutePosition.X)
                                                / bar.AbsoluteSize.X, 0, 1)
                        local r, g, b = color.R, color.G, color.B
                        if channel == "R" then r = rel
                        elseif channel == "G" then g = rel
                        else b = rel end
                        color = Color3.new(r, g, b)
                        update()
                    end
                end)
            end
            bind(rBar, "R"); bind(gBar, "G"); bind(bBar, "B")

            swatch.MouseButton1Click:Connect(function()
                open = not open
                tween(f, 0.2, { Size = UDim2.new(1, 0, 0, open and 130 or 36) })
            end)

            function api:Set(c) color = c; update() end
            update()
            if o.Flag then Aquafield.Flags[o.Flag] = api end
            return api
        end

        return Tab
    end -- CreateTab

    -- autosave
    if Window.Cfg and Window.Cfg.Enabled then
        task.spawn(function()
            while ScreenGui.Parent do task.wait(10); saveConfig(Window) end
        end)
    end

    table.insert(Aquafield._windows, Window)
    return Window
end

-- Rayfield API parity: destroy
function Aquafield:Destroy()
    if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
end

return Aquafield
