local Effects = {}

-- Particle field that floats in the window background.
function Effects.ParticleField(parent, count, color)
    if not Aquafield.EffectsEnabled then return end
    count = count or 32
    local container = Util.New("Frame", {
        Name                  = "ParticleField",
        BackgroundTransparency = 1,
        Size                  = UDim2.fromScale(1, 1),
        ClipsDescendants      = true,
        ZIndex                = 0,
        Parent                = parent,
    })

    local particles = {}
    for i = 1, count do
        local size = math.random(2, 6)
        local p = Util.New("Frame", {
            Size                  = UDim2.fromOffset(size, size),
            Position              = UDim2.fromScale(math.random(), math.random()),
            BackgroundColor3      = color or Color3.fromRGB(120, 200, 255),
            BackgroundTransparency = 0.5 + math.random() * 0.4,
            BorderSizePixel       = 0,
            ZIndex                = 0,
            Parent                = container,
        })
        Util.Corner(p, 999)
        particles[i] = {
            inst  = p,
            vx    = (math.random() - 0.5) * 0.0008,
            vy    = -0.0004 - math.random() * 0.0008,
            depth = 0.3 + math.random() * 0.7,
        }
    end

    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not container.Parent then conn:Disconnect() return end
        for _, p in ipairs(particles) do
            local pos = p.inst.Position
            local nx  = pos.X.Scale + p.vx * 60 * dt * p.depth
            local ny  = pos.Y.Scale + p.vy * 60 * dt * p.depth
            if ny < -0.05 then ny = 1.05; nx = math.random() end
            if nx < -0.05 then nx = 1.05 end
            if nx > 1.05  then nx = -0.05 end
            p.inst.Position = UDim2.fromScale(nx, ny)
        end
    end)
    return container
end

