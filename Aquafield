                        TextSize = 11,
                        TextColor3 = th.SubText,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(0, 14, 1, 0),
                        Parent = row,
                    })
                    local bar = new("Frame", {
                        Position = UDim2.new(0, 20, 0.5, -3),
                        Size = UDim2.new(1, -20, 0, 6),
                        BackgroundColor3 = th.ElementBorder,
                        BackgroundTransparency = 0.5,
                        BorderSizePixel = 0,
                        Parent = row,
                    })
                    corner(bar, 3)
                    local fill = new("Frame", {
                        Size = UDim2.new(getter(), 0, 1, 0),
                        BackgroundColor3 = name == "R" and Color3.fromRGB(255, 80, 80)
                            or name == "G" and Color3.fromRGB(80, 220, 120)
                            or Color3.fromRGB(80, 160, 255),
                        BorderSizePixel = 0,
                        Parent = bar,
                    })
                    corner(fill, 3)
                    return bar, fill
                end
                
                local rBar, rFill = sliderRow("R", 0, function() return color.R end)
                local gBar, gFill = sliderRow("G", 28, function() return color.G end)
                local bBar, bFill = sliderRow("B", 56, function() return color.B end)
                
                local function updateColor()
                    swatch.BackgroundColor3 = color
                    rFill.Size = UDim2.new(color.R, 0, 1, 0)
                    gFill.Size = UDim2.new(color.G, 0, 1, 0)
                    bFill.Size = UDim2.new(color.B, 0, 1, 0)
