-- ============================================================================
-- CONFIGURATION SAVING
-- ============================================================================
local function getConfigFolder(win)
    local folder = win.Cfg and win.Cfg.FolderName or "AquafieldConfigs"
    local name = win.Cfg and win.Cfg.FileName or "Config"
    return folder, name
end

local function getConfigPath(folder, name)
    return "Aquafield/" .. folder .. "/" .. name .. ".json"
end

local function saveConfig(win)
    local ok, folder = pcall(function() return getConfigFolder(win) end)
    if not ok then return end
    local f, n = getConfigFolder(win)
    local data = {}
    for flag, obj in pairs(Aquafield.Flags) do
        local val = obj.CurrentValue
        if val ~= nil then
            -- Convert Color3 to table
            if type(val) == "userdata" and typeof(val) == "Color3" then
                val = {R = val.R, G = val.G, B = val.B}
            end
            data[flag] = val
        end
    end
    local json = HttpService:JSONEncode(data)
    local path = getConfigPath(f, n)
    local suc = pcall(function()
        writefile(path, json)
    end)
    if not suc then
        pcall(function()
            -- Try creating folder
            makefolder("Aquafield")
            makefolder("Aquafield/" .. f)
            writefile(path, json)
        end)
    end
end

local function loadConfig(win)
    local f, n = getConfigFolder(win)
    local path = getConfigPath(f, n)
    local json
    local suc = pcall(function() json = readfile(path) end)
    if not suc or not json then return end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, json)
    if not ok or type(data) ~= "table" then return end
    for flag, val in pairs(data) do
        local obj = Aquafield.Flags[flag]
        if obj and obj.Set then
            -- Convert Color3 table back
            if type(val) == "table" and val.R and val.G and val.B then
                val = Color3.fromRGB(val.R * 255, val.G * 255, val.B * 255)
            end
            pcall(obj.Set, obj, val)
        end
    end
end

