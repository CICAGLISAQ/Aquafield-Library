-- EXTRA: KEYBIND HELPERS  (global key map)
--------------------------------------------------------------------------------
Aquafield._globalBinds = {}
function Aquafield:Bind(keyName, callback)
    self._globalBinds[keyName] = callback
end
function Aquafield:Unbind(keyName)
    self._globalBinds[keyName] = nil
end
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    local cb = Aquafield._globalBinds[input.KeyCode.Name]
    if cb then pcall(cb) end
end)

--------------------------------------------------------------------------------
-- EXTRA: SCREEN UTILITIES
--------------------------------------------------------------------------------
function Aquafield:CenterOnScreen(frame)
    local sz = frame.AbsoluteSize
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.Position    = UDim2.new(0.5, 0, 0.5, 0)
end
function Aquafield:GetViewport()
    local cam = Workspace.CurrentCamera
    if cam then return cam.ViewportSize end
    return Vector2.new(1920, 1080)
end

--------------------------------------------------------------------------------
-- EXTRA: DESTROY / CLEANUP
--------------------------------------------------------------------------------
function Aquafield:Destroy()
    if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
    table.clear(self._windows)
    table.clear(self._themed)
    table.clear(self.Flags)
end

