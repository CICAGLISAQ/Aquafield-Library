-- TOGGLE-UI VISIBILITY  (default keybind: K, user-changeable)
local function setUIVisible(visible)
    Aquafield._hidden = not visible
    for _, w in ipairs(Aquafield._windows) do
        if w._Main then
            local main = w._Main
            if visible then
                main.Visible = true
                main.BackgroundTransparency = 1
                local goalSize = main:GetAttribute("AQF_Size")
                if not goalSize then
                    goalSize = main.Size
                    main:SetAttribute("AQF_Size", goalSize)
                end
                main.Size = UDim2.new(goalSize.X.Scale, goalSize.X.Offset * 0.85,
                                      goalSize.Y.Scale, goalSize.Y.Offset * 0.85)
                tween(main, 0.35, {
                    BackgroundTransparency = 0,
                    Size = goalSize,
                    Rotation = 0,
                }, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
            else
                local goalSize = main:GetAttribute("AQF_Size") or main.Size
                main:SetAttribute("AQF_Size", goalSize)
                local tw = tween(main, 0.28, {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(goalSize.X.Scale, goalSize.X.Offset * 0.85,
                                     goalSize.Y.Scale, goalSize.Y.Offset * 0.85),
                    Rotation = -4,
                }, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
                tw.Completed:Connect(function()
                    if Aquafield._hidden then
                        main.Visible = false
                        main.Size = goalSize
                        main.Rotation = 0
                        main.BackgroundTransparency = 0
                    end
                end)
            end
        end
    end
end

function Aquafield:Toggle()
    setUIVisible(self._hidden)  -- if currently hidden, show
end

function Aquafield:Show()  setUIVisible(true)  end
function Aquafield:Hide()  setUIVisible(false) end

function Aquafield:SetToggleKeybind(keyCodeOrName)
    self.ToggleUIKeybind = keyCodeFromName(keyCodeOrName)
end

