Aquafield.Color = {}
function Aquafield.Color.fromHex(hex)
    hex = hex:gsub("#", "")
    if #hex == 3 then
        hex = hex:sub(1,1):rep(2) .. hex:sub(2,2):rep(2) .. hex:sub(3,3):rep(2)
    end
    local r = tonumber(hex:sub(1,2), 16) or 0
    local g = tonumber(hex:sub(3,4), 16) or 0
    local b = tonumber(hex:sub(5,6), 16) or 0
    return Color3.fromRGB(r, g, b)
end
function Aquafield.Color.toHex(c)
    return string.format("#%02X%02X%02X",
        math.floor(c.R*255+0.5),
        math.floor(c.G*255+0.5),
        math.floor(c.B*255+0.5))
end
function Aquafield.Color.lerp(a, b, t)  return lerpColor(a, b, t) end
function Aquafield.Color.darken(c, f)   return darken(c, f) end
function Aquafield.Color.lighten(c, f)  return lighten(c, f) end
function Aquafield.Color.complement(c)
    return Color3.new(1 - c.R, 1 - c.G, 1 - c.B)
end
function Aquafield.Color.greyscale(c)
    local g = (c.R + c.G + c.B) / 3; return Color3.new(g, g, g)
end

-- EXTRA: SIGNAL  (tiny event helper)
local Signal = {}
Signal.__index = Signal
function Signal.new()
    return setmetatable({ _h = {} }, Signal)
end
function Signal:Connect(fn)
    self._h[#self._h + 1] = fn
    local i = #self._h
    return { Disconnect = function() self._h[i] = nil end }
end
function Signal:Fire(...)
    for _, fn in pairs(self._h) do task.spawn(fn, ...) end
end
Aquafield.Signal = Signal
Aquafield.OnToggle    = Signal.new()
Aquafield.OnThemeChange = Signal.new()

-- hook signals into core API
do
    local origSetTheme = Aquafield.SetTheme
    function Aquafield:SetTheme(name)
        origSetTheme(self, name)
        self.OnThemeChange:Fire(name)
    end
    local origToggle = setUIVisible
    setUIVisible = function(v)
        origToggle(v)
        Aquafield.OnToggle:Fire(v)
    end
end

-- EXTRA: PRESET BUILDERS  (one-line helpers)
function Aquafield:QuickInfo(title, content)
    return self:Notify({ Title = title, Content = content, Duration = 3 })
end
function Aquafield:QuickWarn(title, content)
    return self:Notify({
        Title = title, Content = content, Duration = 4,
        Image = self.Icons.warning,
    })
end
function Aquafield:QuickError(title, content)
    return self:Notify({
        Title = title, Content = content, Duration = 5,
        Image = self.Icons.error,
    })
end
function Aquafield:QuickSuccess(title, content)
    return self:Notify({
        Title = title, Content = content, Duration = 3,
        Image = self.Icons.check,
    })
end

-- EXTRA: MOTION HELPERS  (shake, pulse, fadeIn, fadeOut)
function Aquafield:Shake(inst, intensity, duration)
    intensity = intensity or 4; duration = duration or 0.3
    local start = inst.Position
    local steps = math.floor(duration * 60)
    task.spawn(function()
        for i = 1, steps do
            local dx = (math.random() - 0.5) * intensity * 2
            local dy = (math.random() - 0.5) * intensity * 2
            inst.Position = UDim2.new(
                start.X.Scale, start.X.Offset + dx,
                start.Y.Scale, start.Y.Offset + dy)
            task.wait(1/60)
        end
        inst.Position = start
    end)
end

function Aquafield:Pulse(inst, scale, duration)
    scale = scale or 1.05; duration = duration or 0.2
    local s = inst.Size
    tween(inst, duration / 2, { Size = UDim2.new(
        s.X.Scale * scale, s.X.Offset,
        s.Y.Scale * scale, s.Y.Offset) })
    task.delay(duration / 2, function()
        tween(inst, duration / 2, { Size = s })
    end)
end

function Aquafield:FadeIn(inst, duration)
    duration = duration or 0.25
    if inst:IsA("GuiObject") then
        inst.BackgroundTransparency = 1
        tween(inst, duration, { BackgroundTransparency = 0 })
    end
end
function Aquafield:FadeOut(inst, duration)
    duration = duration or 0.25
    if inst:IsA("GuiObject") then
        tween(inst, duration, { BackgroundTransparency = 1 })
    end
end

-- EXTRA: KEYBIND HELPERS  (global key map)
Aquafield._globalBinds = {}
function Aquafield:Bind(keyName, callback)
    self._globalBinds[keyName] = callback
end
function Aquafield:Unbind(keyName)
    self._globalBinds[keyName] = nil
end
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    local cb = Aquafield._globalBinds[input.KeyCode.Name]
    if cb then pcall(cb) end
end)

function Aquafield:CenterOnScreen(frame)
    local sz = frame.AbsoluteSize
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.Position    = UDim2.new(0.5, 0, 0.5, 0)
end
function Aquafield:GetViewport()
    local cam = Workspace.CurrentCamera
    if cam then return cam.ViewportSize end
    return Vector2.new(1920, 1080)
end

function Aquafield:Destroy()
    if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
    table.clear(self._windows)
    table.clear(self._themed)
    table.clear(self.Flags)
end

do
    local _origSet = Aquafield.SetTheme
    function Aquafield:SetTheme(name)
        _origSet(self, name)
        if saveAquafieldPrefs then pcall(saveAquafieldPrefs) end
    end
end
pcall(loadAquafieldPrefs)
return Aquafield
