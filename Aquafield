local function runKeySystem(settings, theme, onSuccess)
    local th = theme
    local keys = settings.Key or {}
    if type(keys) ~= "table" then keys = { tostring(keys) } end

    local saveFile = "Aquafield_" .. (settings.FileName or "Key") .. ".txt"
    if settings.SaveKey and isfile and readfile and isfile(saveFile) then
        local saved = readfile(saveFile)
        for _, k in ipairs(keys) do
            if tostring(saved) == tostring(k) then onSuccess() return end
        end
    end

    local frame = new("Frame", {
        Size             = UDim2.new(0, 340, 0, 220),
        Position         = UDim2.new(0.5, -170, 0.5, -110),
        BackgroundColor3 = th.Background,
        BorderSizePixel  = 0,
        Parent           = ScreenGui,
    })
    corner(frame, 12); stroke(frame, th.Border, 1, 0.4)

    new("TextLabel", {
        Text = settings.Title or "Key System",
        Font = Enum.Font.GothamBold, TextSize = 16,
        TextColor3 = th.Text, BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 16),
        Size = UDim2.new(1, 0, 0, 22), Parent = frame,
    })
    new("TextLabel", {
        Text = settings.Subtitle or "",
        Font = Enum.Font.Gotham, TextSize = 12,
        TextColor3 = th.SubText, BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 40),
        Size = UDim2.new(1, 0, 0, 16), Parent = frame,
    })
    new("TextLabel", {
        Text = settings.Note or "",
        Font = Enum.Font.Gotham, TextSize = 11,
        TextColor3 = th.SubText, BackgroundTransparency = 1, TextWrapped = true,
        Position = UDim2.new(0, 16, 0, 64),
        Size = UDim2.new(1, -32, 0, 40), Parent = frame,
    })

    local box = new("TextBox", {
        PlaceholderText = "Enter key...", Text = "",
        Font = Enum.Font.Gotham, TextSize = 13,
        TextColor3 = th.Text, PlaceholderColor3 = th.SubText,
        BackgroundColor3 = th.Element, ClearTextOnFocus = false,
        Position = UDim2.new(0, 16, 0, 116),
        Size = UDim2.new(1, -32, 0, 32), Parent = frame,
    })
    corner(box, 6); stroke(box, th.Border, 1, 0.4)

    local btn = new("TextButton", {
        Text = "Submit", Font = Enum.Font.GothamBold, TextSize = 13,
        TextColor3 = th.Background, BackgroundColor3 = th.Accent,
        Position = UDim2.new(0, 16, 0, 160),
        Size = UDim2.new(1, -32, 0, 34),
        AutoButtonColor = false, Parent = frame,
    })
    corner(btn, 6)
    gradient(btn, lighten(th.Accent, 0.15), th.Accent, 90)

    btn.MouseButton1Click:Connect(function()
        local entered = box.Text
        local keysNow = keys
        if settings.GrabKeyFromSite and #keys == 1 then
            pcall(function() keysNow = { game:HttpGet(keys[1]) } end)
        end
        for _, k in ipairs(keysNow) do
            if tostring(entered) == tostring(k) then
                if settings.SaveKey and writefile then
                    pcall(writefile, saveFile, tostring(entered))
                end
                frame:Destroy(); onSuccess(); return
            end
        end
        box.Text = ""; box.PlaceholderText = "Invalid key, try again"
    end)
end

--------------------------------------------------------------------------------
-- TOGGLE-UI VISIBILITY  (default keybind: K, user-changeable)
--------------------------------------------------------------------------------
local function setUIVisible(visible)
    Aquafield._hidden = not visible
    for _, w in ipairs(Aquafield._windows) do
        if w._Main then
            w._Main.Visible = visible
        end
    end
end

function Aquafield:Toggle()
    setUIVisible(self._hidden)  -- if currently hidden, show
end

function Aquafield:Show()  setUIVisible(true)  end
function Aquafield:Hide()  setUIVisible(false) end

function Aquafield:SetToggleKeybind(keyCodeOrName)
    self.ToggleUIKeybind = keyCodeFromName(keyCodeOrName)
end

-- Global keybind listener (one for the whole library)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode == Aquafield.ToggleUIKeybind then
        Aquafield:Toggle()
    end
end)

