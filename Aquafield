            BorderSizePixel  = 0,
            Parent           = ScreenGui,
            ClipsDescendants = true,
        })
        corner(Main, 14)
        stroke(Main, th.Border, 1, 0.2)
        themed(Main, "Background")

        -- ============================================================
        -- ANIMATED FX STACK (background gradient → halo → shimmer)
        -- ============================================================
        --  Layer 1 : full-window themed gradient that rotates slowly,
        --            colours sourced from the active theme's Bg stops.
        --  Layer 2 : breathing accent halo (sine-wave transparency).
        --  Layer 3 : diagonal shimmer sweep that re-paints across the
        --            window every couple of seconds.
        --  Layer 4 : drifting accent orb behind the topbar for ambient
        --            motion.
        --  Layer 5 : particle field (unchanged, but accent-tinted).

        -- L1: themed gradient backdrop
        local bgFx = new("Frame", {
            Name                   = "BgGradientFx",
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundColor3       = Color3.fromRGB(255, 255, 255),
            BackgroundTransparency = 0.0,
            BorderSizePixel        = 0,
            ZIndex                 = 0,
            Parent                 = Main,
        })
        corner(bgFx, 14)
        local bgGrad = buildThemedGradient(bgFx, 35)
        fxThemedRotate(bgGrad, 6)

        -- L2: accent halo (breathing)
        local halo = new("Frame", {
            Name                   = "AccentHalo",
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundColor3       = th.Accent,
            BackgroundTransparency = 0.92,
            BorderSizePixel        = 0,
            ZIndex                 = 1,
            Parent                 = Main,
        })
        corner(halo, 14)
        themed(halo, "Accent")
        gradient(halo,
            Color3.fromRGB(255, 255, 255),
            Color3.fromRGB(0,   0,   0),  135)
        fxBreathe(halo, 0.86, 0.94, 1.1)

        -- L3: shimmer sweep
        local shimmer = new("Frame", {
            Name                   = "Shimmer",
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundColor3       = Aquafield.Theme.ShimmerHue or Color3.fromRGB(255,255,255),
            BackgroundTransparency = 0.5,
            BorderSizePixel        = 0,
            ZIndex                 = 2,
            Parent                 = Main,
        })
        corner(shimmer, 14)
        local shimmerGrad = buildShimmerGradient(shimmer)
        fxShimmer(shimmerGrad, 0.35)

        -- L4: drifting accent orb (sits behind the topbar)
        local orb = new("Frame", {
            Name                   = "AccentOrb",
            Size                   = UDim2.new(0, 220, 0, 220),
            Position               = UDim2.new(0, -60, 0, -60),
            BackgroundColor3       = th.Accent,
            BackgroundTransparency = 0.82,
            BorderSizePixel        = 0,
            ZIndex                 = 1,
            Parent                 = Main,
        })
        corner(orb, 200); themed(orb, "Accent")
        gradient(orb,
            Aquafield.Theme.AccentA or th.Accent,
            Aquafield.Theme.AccentB or th.AccentSoft, 90)
        fxDrift(orb, 16, 10, 0.6, UDim2.new(0, -60, 0, -60))
        fxBreathe(orb, 0.78, 0.9, 0.8)

        -- L5: particle field (existing)
        startParticleField(Main)

        -- Topbar
        local Top = new("Frame", {
            Size             = UDim2.new(1, 0, 0, 40),
            BackgroundColor3 = th.Topbar,
            BorderSizePixel  = 0,
            Parent           = Main,
        })
        themed(Top, "Topbar")
        new("Frame", {
            Size = UDim2.new(1, 0, 0, 1),
            Position = UDim2.new(0, 0, 1, 0),
            BackgroundColor3 = th.Border,
            BorderSizePixel = 0, Parent = Top,
        })
        makeDraggable(Main, Top)

        local titleX = 16
        if opts.Icon and opts.Icon ~= 0 then
            local iconImg = typeof(opts.Icon) == "number"
                and ("rbxassetid://" .. tostring(opts.Icon))
                or tostring(opts.Icon)
