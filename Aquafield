local function getParentGui()
    local target = CoreGui
    if not pcall(function() return CoreGui.Name end) then
        target = LocalPlayer:WaitForChild("PlayerGui")
    end
    for _, old in ipairs(target:GetChildren()) do
        if old.Name == "AquafieldUI" then old:Destroy() end
    end
    return target
end

