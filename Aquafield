-- UTIL  ::  the engine room
--------------------------------------------------------------------------------
local Util = {}

-- Fast instance creator.  Properties table, then optional children table.
function Util.New(class, props, children)
    local inst = Instance.new(class)
    if props then
        for k, v in pairs(props) do
            if k ~= "Parent" then inst[k] = v end
        end
        if props.Parent then inst.Parent = props.Parent end
    end
    if children then
        for _, c in ipairs(children) do c.Parent = inst end
    end
    return inst
end

-- Tween shorthand.  Returns the tween so you can :Play()/:Cancel().
function Util.Tween(obj, time, props, style, dir)
    local info = TweenInfo.new(
        time or 0.2,
        style or Enum.EasingStyle.Quint,
        dir   or Enum.EasingDirection.Out
    )
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

-- Spring physics step (Hookean: a = -k*x - c*v).  Returns updated x, v.
function Util.SpringStep(x, v, target, k, c, dt)
    local a = -k * (x - target) - c * v
    v = v + a * dt
    x = x + v * dt
    return x, v
end

-- Linear interpolate two Color3s.
function Util.LerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

-- Add a UICorner.  Returns the corner.
function Util.Corner(parent, rad)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, rad or 6)
    c.Parent = parent
    return c
end

-- Add a UIStroke with optional gradient.
function Util.Stroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(255,255,255)
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

-- Apply a 2-stop gradient.
function Util.Gradient(parent, c1, c2, rotation)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(c1, c2)
    g.Rotation = rotation or 0
    g.Parent = parent
    return g
end

-- Soft drop shadow using a stretched ImageLabel-less Frame stack.
function Util.Shadow(parent, color, transparency, size)
    local s = Instance.new("Frame")
    s.Name = "Shadow"
    s.AnchorPoint = Vector2.new(0.5, 0.5)
    s.Position = UDim2.fromScale(0.5, 0.55)
    s.Size = UDim2.new(1, size or 32, 1, size or 32)
    s.BackgroundColor3 = color or Color3.fromRGB(0,0,0)
    s.BackgroundTransparency = transparency or 0.6
    s.BorderSizePixel = 0
    s.ZIndex = (parent.ZIndex or 1) - 1
    Util.Corner(s, 16)
    s.Parent = parent
    return s
end

-- Glow halo: a sibling frame with gradient and high transparency.
function Util.Glow(parent, color)
    local g = Instance.new("Frame")
    g.Name = "Glow"
    g.AnchorPoint = Vector2.new(0.5, 0.5)
    g.Position = UDim2.fromScale(0.5, 0.5)
    g.Size = UDim2.new(1, 20, 1, 20)
    g.BackgroundColor3 = color or Color3.fromRGB(120, 200, 255)
    g.BackgroundTransparency = 0.85
    g.BorderSizePixel = 0
    g.ZIndex = (parent.ZIndex or 1) - 1
    Util.Corner(g, 12)
    g.Parent = parent
    return g
end

-- Liquid ripple on click.  Spawns at mouse coords inside `parent`.
function Util.Ripple(parent, x, y, color)
    local ripple = Instance.new("Frame")
    ripple.AnchorPoint = Vector2.new(0.5, 0.5)
    ripple.Position = UDim2.fromOffset(x, y)
    ripple.Size = UDim2.fromOffset(0, 0)
    ripple.BackgroundColor3 = color or Color3.fromRGB(255, 255, 255)
    ripple.BackgroundTransparency = 0.45
    ripple.BorderSizePixel = 0
    Util.Corner(ripple, 999)
    ripple.Parent = parent
    ripple.ZIndex = parent.ZIndex + 5

    local maxSize = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2.2
    Util.Tween(ripple, 0.55, {
        Size                  = UDim2.fromOffset(maxSize, maxSize),
        BackgroundTransparency = 1,
    }, Enum.EasingStyle.Quad)
    task.delay(0.6, function() ripple:Destroy() end)
end

-- Clamp a number.
function Util.Clamp(v, lo, hi) return math.max(lo, math.min(hi, v)) end

-- Round to nearest step.
function Util.Snap(v, step)
    if not step or step == 0 then return v end
    return math.floor(v / step + 0.5) * step
end

-- Generate a UUID-ish flag id when none provided.
function Util.UUID()
    return string.format("%08x-%04x", math.random(0, 0xFFFFFFFF), math.random(0, 0xFFFF))
end

-- Safe parent for a ScreenGui (Roblox: CoreGui in exploit, PlayerGui in studio).
function Util.SafeParent(gui)
    local ok = pcall(function() gui.Parent = CoreGui end)
    if not ok then
        gui.Parent = LP:WaitForChild("PlayerGui")
    end
end

-- Make a frame draggable by a handle.
function Util.MakeDraggable(handle, target)
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = target.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
            -- Clamp to viewport so the window can't escape (bugfix).
            local vp = Camera.ViewportSize
            local absSize = target.AbsoluteSize
            local minX = -absSize.X * 0.5
            local maxX = vp.X - absSize.X * 0.5
            local minY = 0
            local maxY = vp.Y - 40
            local nx = Util.Clamp(newPos.X.Offset, minX, maxX)
            local ny = Util.Clamp(newPos.Y.Offset, minY, maxY)
            target.Position = UDim2.new(newPos.X.Scale, nx, newPos.Y.Scale, ny)
        end
    end)
end


