-- EXTRA: SIGNAL  (tiny event helper)
--------------------------------------------------------------------------------
local Signal = {}
Signal.__index = Signal
function Signal.new()
    return setmetatable({ _h = {} }, Signal)
end
function Signal:Connect(fn)
    self._h[#self._h + 1] = fn
    local i = #self._h
    return { Disconnect = function() self._h[i] = nil end }
end
function Signal:Fire(...)
    for _, fn in pairs(self._h) do task.spawn(fn, ...) end
end
Aquafield.Signal = Signal
Aquafield.OnToggle    = Signal.new()
Aquafield.OnThemeChange = Signal.new()

-- hook signals into core API
do
    local origSetTheme = Aquafield.SetTheme
    function Aquafield:SetTheme(name)
        origSetTheme(self, name)
        self.OnThemeChange:Fire(name)
    end
    local origToggle = setUIVisible
    setUIVisible = function(v)
        origToggle(v)
        Aquafield.OnToggle:Fire(v)
    end
end

