--------------------------------------------------------------------------------
-- CONFIG SAVING / LOADING
--------------------------------------------------------------------------------
local function configPath(w)
    local folder = w.Cfg.FolderName
    if folder and #folder > 0 then
        return ("%s/%s.json"):format(folder, w.Cfg.FileName or "Config")
    end
    return ("Aquafield_%s.json"):format(w.Cfg.FileName or "Config")
end

local function saveConfig(w)
    if not (w and w.Cfg and w.Cfg.Enabled and writefile) then return end
    pcall(function()
        if w.Cfg.FolderName and #w.Cfg.FolderName > 0
           and makefolder and isfolder and not isfolder(w.Cfg.FolderName) then
            makefolder(w.Cfg.FolderName)
        end
        local data = { _meta = {
            theme    = Aquafield.ThemeName,
            keybind  = Aquafield.ToggleUIKeybind.Name,
            acrylic  = Aquafield.AcrylicStrength,
            notifSide= Aquafield.NotifSide,
        }}
        for k, v in pairs(Aquafield.Flags) do
            local cv = v.CurrentValue
            if typeof(cv) == "Color3" then
                data[k] = { "Color3", cv.R, cv.G, cv.B }
            else
                data[k] = cv
            end
        end
        writefile(configPath(w), HttpService:JSONEncode(data))
    end)
end

local function loadConfigFor(w)
    if not (w and w.Cfg and w.Cfg.Enabled and readfile and isfile) then return end
    pcall(function()
        if not isfile(configPath(w)) then return end
        local data = HttpService:JSONDecode(readfile(configPath(w)))
        local meta = data._meta
        if meta then
            if meta.theme    then Aquafield:SetTheme(meta.theme) end
            if meta.keybind  then Aquafield.ToggleUIKeybind = keyCodeFromName(meta.keybind) end
            if meta.acrylic  then Aquafield.AcrylicStrength = meta.acrylic end
            if meta.notifSide then positionNotifHolder(meta.notifSide) end
            data._meta = nil
        end
        for k, v in pairs(data) do
            local f = Aquafield.Flags[k]
            if f and f.Set then
                if type(v) == "table" and v[1] == "Color3" then
                    f:Set(Color3.new(v[2], v[3], v[4]))
                else
                    f:Set(v)
                end
            end
        end
    end)
end

function Aquafield:LoadConfiguration()
    local w = self._windows[#self._windows]
    if w then loadConfigFor(w) end
end

