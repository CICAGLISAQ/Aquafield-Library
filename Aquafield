function ShadowField:CreateDropdown(window, section, dropdownConfig)
    local theme = window.Theme
    local elemTheme = theme.Element
    local ddTheme = theme.Dropdown
    
    local options = dropdownConfig.Options or {}
    local selectedOption = dropdownConfig.Default or (options[1] or "")
    local isOpen = false
    
    -- Load saved
    if window.SavedData and dropdownConfig.Name then
        local saved = window.SavedData[dropdownConfig.Name]
        if saved and table.find(options, saved) then
            selectedOption = saved
        end
    end
    
    local dropdownFrame = self:Create("Frame", {
        BackgroundColor3 = elemTheme.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 36),
        Parent = section.ElementsContainer,
    })
    
    local dropdownCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = dropdownFrame,
    })
    
    -- Label
    local label = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        Font = Enum.Font.Gotham,
        Text = dropdownConfig.Name or "Dropdown",
        TextColor3 = elemTheme.TextColor,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = dropdownFrame,
    })
    
    -- Selected display
    local selectedText = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 100, 1, 0),
        Position = UDim2.new(1, -110, 0, 0),
        Font = Enum.Font.Gotham,
        Text = selectedOption,
        TextColor3 = elemTheme.AccentColor or theme.Window.AccentColor,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = dropdownFrame,
    })
    
    -- Arrow
    local arrow = self:Create("ImageLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(1, -16, 0.5, -6),
        Image = "rbxassetid://6031094678",
        ImageColor3 = elemTheme.SubTextColor,
        Rotation = 0,
        Parent = dropdownFrame,
    })
    
    -- Dropdown container (for options)
    local ddContainer = self:Create("Frame", {
        BackgroundColor3 = ddTheme.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, 36),
        ClipsDescendants = true,
        Visible = false,
        ZIndex = 5,
        Parent = dropdownFrame,
    })
    
    local ddCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = ddContainer,
    })
    
    -- Options list
    local optionsList = self:Create("ScrollingFrame", {
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -8, 1, -8),
        Position = UDim2.new(0, 4, 0, 4),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 3,
        ScrollBarImage
        ScrollBarImageColor3 = Color3.fromRGB(40, 40, 50),
    AutomaticCanvasSize = Enum.AutomaticSize.Y,
    Parent = ddContainer,
})

local optionsLayout = self:Create("UIListLayout", {
    Padding = UDim.new(0, 2),
    SortOrder = Enum.SortOrder.LayoutOrder,
    Parent = optionsList,
})

-- Create option buttons
local optionButtons = {}
for _, opt in ipairs(options) do
    local optBtn = self:Create("TextButton", {
        BackgroundColor3 = (opt == selectedOption) and ddTheme.SelectedColor or ddTheme.ItemColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 28),
        Font = Enum.Font.Gotham,
        Text = opt,
        TextColor3 = ddTheme.TextColor,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Center,
        AutoButtonColor = false,
        Parent = optionsList,
    })
    
    local optCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 4),
        Parent = optBtn,
    })
    
    optBtn.MouseEnter:Connect(function()
        if opt ~= selectedOption then
            self:TweenObject(optBtn, {
                BackgroundColor3 = ddTheme.HoverColor,
            }, TweenInfo.new(0.1))
        end
    end)
    optBtn.MouseLeave:Connect(function()
        if opt ~= selectedOption then
            self:TweenObject(optBtn, {
                BackgroundColor3 = ddTheme.ItemColor,
            }, TweenInfo.new(0.1))
        end
    end)
    optBtn.MouseButton1Click:Connect(function()
        selectedOption = opt
        selectedText.Text = opt
        
        -- Update highlights
        for _, btn in ipairs(optionButtons) do
            self:TweenObject(btn, {
                BackgroundColor3 = ddTheme.ItemColor,
            }, TweenInfo.new(0.1))
        end
        self:TweenObject(optBtn, {
            BackgroundColor3 = ddTheme.SelectedColor,
        }, TweenInfo.new(0.1))
        
        -- Close dropdown
        CloseDropdown()
        
        -- Save
        if dropdownConfig.Name and window.ConfigSave.Enabled then
            window.SavedData[dropdownConfig.Name] = opt
            ShadowField:SaveConfiguration(
                window.ConfigSave.FolderName,
                window.ConfigSave.FileName,
                window.SavedData
            )
        end
        
        if dropdownConfig.Callback then
            pcall(dropdownConfig.Callback, opt)
        end
    end)
    
    table.insert(optionButtons, optBtn)
end

local function CloseDropdown()
    if not isOpen then return end
    isOpen = false
    self:TweenObject(ddContainer, {
        Size = UDim2.new(1, 0, 0, 0),
    }, TweenInfo.new(0.2))
    self:TweenObject(arrow, {
        Rotation = 0,
    }, TweenInfo.new(0.2))
    task.delay(0.2, function()
        ddContainer.Visible = false
        dropdownFrame.Size = UDim2.new(1, 0, 0, 36)
    end)
end

local function OpenDropdown()
    if isOpen then return end
    isOpen = true
    local count = #options
    local height = math.min(count * 30 + 8, 180)
    dropdownFrame.Size = UDim2.new(1, 0, 0, 36 + height + 4)
    ddContainer.Visible = true
    ddContainer.Size = UDim2.new(1, 0, 0, 0)
    self:TweenObject(ddContainer, {
        Size = UDim2.new(1, 0, 0, height),
    }, TweenInfo.new(0.25, Enum.EasingStyle.Quint))
    self:TweenObject(arrow, {
        Rotation = 180,
    }, TweenInfo.new(0.2))
end

-- Toggle dropdown when clicking
dropdownFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if isOpen then
            CloseDropdown()
        else
            OpenDropdown()
        end
    end
end)

-- Hover
dropdownFrame.MouseEnter:Connect(function()
    self:TweenObject(dropdownFrame, {BackgroundColor3 = elemTheme.HoverColor}, TweenInfo.new(0.15))
end)
dropdownFrame.MouseLeave:Connect(function()
    self:TweenObject(dropdownFrame, {BackgroundColor3 = elemTheme.BackgroundColor}, TweenInfo.new(0.15))
end)

section.UpdateSize()

return {
    Frame = dropdownFrame,
    Set = function(self, option)
        if table.find(options, option) then
            selectedOption = option
            selectedText.Text = option
            for _, btn in ipairs(optionButtons) do
                self:TweenObject(btn, {BackgroundColor3 = (btn.Text == option) and ddTheme.SelectedColor or ddTheme.ItemColor}, TweenInfo.new(0.1))
            end
        end
    end,
    Get = function(self) return selectedOption end,
    SetCallback = function(self, cb) dropdownConfig.Callback = cb end,
    Destroy = function(self)
        dropdownFrame:Destroy()
        section.UpdateSize()
    end,
}
end

