        Name = sectionConfig.Name or "Section",
        BackgroundColor3 = elemTheme.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 0),
        Parent = tab.SectionsContainer,
    })
    
    local sectionCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 8),
        Parent = section,
    })
    
    -- Section header
    local sectionHeader = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -20, 0, 30),
        Position = UDim2.new(0, 12, 0, 6),
        Font = Enum.Font.GothamSemibold,
        Text = sectionConfig.Name or "Section",
        TextColor3 = elemTheme.TextColor,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = section,
    })
    
    -- Elements container
    local elementsContainer = self:Create("Frame", {
        Name = "Elements",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -20, 0, 0),
        Position = UDim2.new(0, 12, 0, 38),
        Parent = section,
    })
    
    local elementsLayout = self:Create("UIListLayout", {
        Padding = UDim.new(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = elementsContainer,
    })
    
    -- Section object
    local Section = {
        Name = sectionConfig.Name,
        SectionFrame = section,
        ElementsContainer = elementsContainer,
        Elements = {},
        
        CreateButton = function(self, btnConfig)
            return ShadowField:CreateButton(window, self, btnConfig)
        end,
        
        CreateToggle = function(self, toggleConfig)
            return ShadowField:CreateToggle(window, self, toggleConfig)
        end,
        
        CreateSlider = function(self, sliderConfig)
            return ShadowField:CreateSlider(window, self, sliderConfig)
        end,
        
        CreateDropdown = function(self, dropdownConfig)
            return ShadowField:CreateDropdown(window, self, dropdownConfig)
        end,
        
        CreateInput = function(self, inputConfig)
            return ShadowField:CreateInput(window, self, inputConfig)
        end,
        
        CreateKeybind = function(self, keybindConfig)
            return ShadowField:CreateKeybind(window, self, keybindConfig)
        end,
        
        CreateLabel = function(self, labelConfig)
            return ShadowField:CreateLabel(window, self, labelConfig)
        end,
        
        CreateSeparator = function(self)
            return ShadowField:CreateSeparator(window, self)
        end,
    }
    
    tab.Sections[sectionConfig.Name] = Section
    table.insert(tab.Sections, Section)
    
    -- Update section size
    local function UpdateSize()
        local totalHeight = 38 + 8  -- header + padding
        for _, v in ipairs(elementsContainer:GetChildren()) do
            if v:IsA("Frame") then
                totalHeight = totalHeight + v.Size.Y.Offset + 6
            end
        end
        section.Size = UDim2.new(1, 0, 0, totalHeight)
    end
    
    Section.UpdateSize = UpdateSize
    
    return Section
end

