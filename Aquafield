--------------------------------------------------------------------------------
-- CORE HELPERS  (instance, tween, corner, stroke, etc.)
--------------------------------------------------------------------------------
local function new(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do inst[k] = v end
    for _, c in ipairs(children or {}) do c.Parent = inst end
    return inst
end

local function tween(o, t, props, style, dir)
    local info = TweenInfo.new(
        t or 0.2,
        style or Enum.EasingStyle.Quad,
        dir or Enum.EasingDirection.Out)
    local tw = TweenService:Create(o, info, props)
    tw:Play()
    return tw
end

local function spring(o, t, props)
    -- back-out easing for that springy entrance
    return tween(o, t or 0.45, props, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

local function corner(parent, r)
    return new("UICorner", { CornerRadius = UDim.new(0, r or 8), Parent = parent })
end

local function stroke(parent, color, thick, trans)
    return new("UIStroke", {
        Color           = color or Color3.fromRGB(255, 255, 255),
        Thickness       = thick or 1,
        Transparency    = trans or 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent          = parent,
    })
end

local function pad(parent, x, y)
    y = y or x or 8
    x = x or 8
    return new("UIPadding", {
        PaddingTop    = UDim.new(0, y),
        PaddingBottom = UDim.new(0, y),
        PaddingLeft   = UDim.new(0, x),
        PaddingRight  = UDim.new(0, x),
        Parent        = parent,
    })
end

local function gradient(parent, c1, c2, rot)
    return new("UIGradient", {
        Color    = ColorSequence.new(c1, c2),
        Rotation = rot or 90,
        Parent   = parent,
    })
end

local function lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t)
end

local function darken(c, f)
    return Color3.new(
        math.clamp(c.R * (1 - f), 0, 1),
        math.clamp(c.G * (1 - f), 0, 1),
        math.clamp(c.B * (1 - f), 0, 1))
end

local function lighten(c, f)
    return Color3.new(
        math.clamp(c.R + (1 - c.R) * f, 0, 1),
        math.clamp(c.G + (1 - c.G) * f, 0, 1),
        math.clamp(c.B + (1 - c.B) * f, 0, 1))
end

local function keyCodeFromName(name)
    if typeof(name) == "EnumItem" then return name end
    if type(name) ~= "string" then return Enum.KeyCode.K end
    local ok, kc = pcall(function() return Enum.KeyCode[name] end)
    if ok and kc then return kc end
    return Enum.KeyCode.K
end

--------------------------------------------------------------------------------
-- THEME REGISTRY  (live-recolor every themed instance)
--------------------------------------------------------------------------------
local function themed(inst, key, role)
    Aquafield._themed[#Aquafield._themed + 1] = { inst = inst, key = key, role = role or "bg" }
end

local function applyThemeColors()
    local th = Aquafield.Theme
    for _, entry in ipairs(Aquafield._themed) do
        local inst, key, role = entry.inst, entry.key, entry.role
        if inst and inst.Parent then
            local c = th[key]
            if c then
                if     role == "text"   then inst.TextColor3       = c
                elseif role == "image"  then inst.ImageColor3      = c
                elseif role == "stroke" and inst:IsA("UIStroke") then inst.Color = c
                elseif role == "placeholder" then inst.PlaceholderColor3 = c
                else inst.BackgroundColor3 = c end
            end
        end
    end
end

function Aquafield:SetTheme(name)
    if not Themes[name] then return end
    self.ThemeName = name
    self.Theme     = Themes[name]
    applyThemeColors()
end

