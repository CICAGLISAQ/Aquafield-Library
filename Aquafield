function Aquafield:Notify(opts)
    opts = opts or {}
    local title    = opts.Title or "Notification"
    local content  = opts.Content or ""
    local duration = opts.Duration or 4
    local image    = opts.Image
    local th       = Aquafield.Theme

    -- support Rayfield numeric Image ids
    if typeof(image) == "number" then image = "rbxassetid://" .. tostring(image) end

    local card = new("Frame", {
        Size = UDim2.new(1, 0, 0, 74),
        BackgroundColor3 = th.Sidebar, BackgroundTransparency = 0.05,
        Position = UDim2.new(1, 50, 0, 0), Parent = NotifHolder,
    })
    corner(card, 10)
    stroke(card, th.Border, 1, 0.4)
    themed(card, "Sidebar")

    local accent = new("Frame", {
        Size = UDim2.new(0, 3, 1, -16),
        Position = UDim2.new(0, 8, 0, 8),
        BackgroundColor3 = th.Accent, BorderSizePixel = 0, Parent = card,
    })
    corner(accent, 2); themed(accent, "Accent")

    local left = 18
    if image then
        local img = new("ImageLabel", {
            Image = image, Size = UDim2.new(0, 30, 0, 30),
            Position = UDim2.new(0, 18, 0, 14),
            BackgroundTransparency = 1,
            ImageColor3 = th.Accent, Parent = card,
        })
        themed(img, "Accent", "image")
        left = 56
    end

    local titleLbl = new("TextLabel", {
        Text = title, Font = Enum.Font.GothamBold, TextSize = 14,
        TextColor3 = th.Text, BackgroundTransparency = 1,
        Position = UDim2.new(0, left, 0, 10),
        Size = UDim2.new(1, -left - 12, 0, 18),
        TextXAlignment = Enum.TextXAlignment.Left, Parent = card,
    })
    themed(titleLbl, "Text", "text")

    local body = new("TextLabel", {
        Text = content, Font = Enum.Font.Gotham, TextSize = 12,
        TextColor3 = th.SubText, BackgroundTransparency = 1,
        Position = UDim2.new(0, left, 0, 30),
        Size = UDim2.new(1, -left - 12, 1, -40),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true, Parent = card,
    })
    themed(body, "SubText", "text")

    local bar = new("Frame", {
        Size = UDim2.new(1, -16, 0, 2),
        Position = UDim2.new(0, 8, 1, -6),
        BackgroundColor3 = th.Accent, BorderSizePixel = 0, Parent = card,
    })
    corner(bar, 2); themed(bar, "Accent")

    tween(card, 0.35, { Position = UDim2.new(0, 0, 0, 0) }, Enum.EasingStyle.Quint)
    tween(bar, duration, { Size = UDim2.new(0, 0, 0, 2) }, Enum.EasingStyle.Linear)

    task.delay(duration, function()
        tween(card, 0.3, { Position = UDim2.new(1, 50, 0, 0), BackgroundTransparency = 1 })
        task.wait(0.35); card:Destroy()
    end)
end

function Aquafield:SetTheme(name)
    if not Themes[name] then return end
    Aquafield.ThemeName = name
    Aquafield.Theme = Themes[name]
    applyThemeColors()
end

