local Aquafield = {
    Flags     = {},
    Theme     = Themes.Ocean,
    ThemeName = "Ocean",
    _windows  = {},
    _themed   = {},
}

local function new(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do inst[k] = v end
    for _, c in ipairs(children or {}) do c.Parent = inst end
    return inst
end

local function tween(o, t, props, style, dir)
    local info = TweenInfo.new(t or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
    local tw = TweenService:Create(o, info, props)
    tw:Play()
    return tw
end

local function corner(p, r) return new("UICorner", { CornerRadius = UDim.new(0, r or 6), Parent = p }) end
local function stroke(p, c, t, tr)
    return new("UIStroke", {
        Color = c or Color3.fromRGB(255,255,255), Thickness = t or 1,
        Transparency = tr or 0, ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Parent = p,
    })
end
local function pad(p, x)
    x = x or 8
    return new("UIPadding", {
        PaddingTop = UDim.new(0, x), PaddingBottom = UDim.new(0, x),
        PaddingLeft = UDim.new(0, x), PaddingRight = UDim.new(0, x), Parent = p,
    })
end

local function themed(inst, key, role)
    Aquafield._themed[#Aquafield._themed + 1] = { inst = inst, key = key, role = role }
end

local function applyThemeColors()
    for _, t in ipairs(Aquafield._themed) do
        local inst, key, role = t.inst, t.key, t.role
        if inst and inst.Parent then
            local c = Aquafield.Theme[key]
            if c then
                if role == "text" then inst.TextColor3 = c
                elseif role == "image" then inst.ImageColor3 = c
                elseif role == "stroke" and inst:IsA("UIStroke") then inst.Color = c
                else inst.BackgroundColor3 = c end
            end
        end
    end
end

----------------------------------------------------------------
-- DRAG
----------------------------------------------------------------
local function makeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                      or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X,
                                       startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
end

