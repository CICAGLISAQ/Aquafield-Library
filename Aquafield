                    end)
                    ob.MouseLeave:Connect(function()
                        tween(ob, 0.1, { BackgroundColor3 = Aquafield.Theme.Background })
                    end)
                    ob.MouseButton1Click:Connect(function()
                        if multi then
                            local found
                            for i, v in ipairs(current) do
                                if v == opt then found = i break end
                            end
                            if found then table.remove(current, found)
                            else            table.insert(current, opt) end
                        else
                            current = opt
                        end
                        api.CurrentOption = current
                        renderValue(); refreshHighlights()
                        if o.Callback then pcall(o.Callback, current) end
                    end)
                end
                refreshHighlights()
            end
            build()

            btn.MouseButton1Click:Connect(function()
                open = not open
                local h = 38 + (open and (#options * 30 + 8) or 0)
                tween(f,   0.22, { Size = UDim2.new(1, 0, 0, h) })
                tween(arr, 0.22, { Rotation = open and 180 or 0 })
            end)

            function api:Set(v)
                current = v; api.CurrentOption = v
                renderValue(); refreshHighlights()
                if o.Callback then pcall(o.Callback, v) end
            end
            function api:Refresh(newOpts) options = newOpts; build() end
            api.CurrentOption = current
            renderValue()
            if o.Flag then Aquafield.Flags[o.Flag] = api end
            return api
        end
    

