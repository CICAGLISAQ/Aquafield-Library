function ShadowField:CreateButton(window, section, btnConfig)
    local theme = window.Theme
    local elemTheme = theme.Element
    
    local btnFrame = self:Create("Frame", {
        BackgroundColor3 = elemTheme.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 36),
        Parent = section.ElementsContainer,
    })
    
    local btnCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = btnFrame,
    })
    
    local button = self:Create("TextButton", {
        BackgroundColor3 = Color3.fromRGB(30, 30, 40),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        Font = Enum.Font.GothamSemibold,
        Text = btnConfig.Name or "Button",
        TextColor3 = elemTheme.TextColor,
        TextSize = 14,
        AutoButtonColor = false,
        Parent = btnFrame,
    })
    
    local btnInnerCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = button,
    })
    
    -- Info tooltip
    if btnConfig.Info then
        local infoIcon = self:Create("ImageLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 16, 0, 16),
            Position = UDim2.new(1, -22, 0.5, -8),
            Image = "rbxassetid://6031094678",
            ImageColor3 = elemTheme.SubTextColor,
            ImageTransparency = 0.5,
            Parent = button,
        })
    end
    
    button.MouseEnter:Connect(function()
        self:TweenObject(button, {
            BackgroundColor3 = Color3.fromRGB(40, 40, 52),
        }, TweenInfo.new(0.15))
    end)
    
    button.MouseLeave:Connect(function()
        self:TweenObject(button, {
            BackgroundColor3 = Color3.fromRGB(30, 30, 40),
        }, TweenInfo.new(0.15))
    end)
    
    button.MouseButton1Click:Connect(function()
        -- Click effect
        self:TweenObject(button, {
            BackgroundColor3 = elemTheme.AccentColor or theme.Window.AccentColor,
        }, TweenInfo.new(0.1))
        task.delay(0.1, function()
            self:TweenObject(button, {
                BackgroundColor3 = Color3.fromRGB(30, 30, 40),
            }, TweenInfo.new(0.1))
        end)
        
        if btnConfig.Callback then
            pcall(btnConfig.Callback)
        end
    end)
    
    section.UpdateSize()
    
    return {
        Button = button,
        Frame = btnFrame,
        SetText = function(self, text)
            button.Text = text
        end,
        SetCallback = function(self, cb)
            btnConfig.Callback = cb
        end,
        Destroy = function(self)
            btnFrame:Destroy()
            section.UpdateSize()
        end,
    }
end

