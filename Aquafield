            tween(Main, 0.25, {
                Size = minimized
                    and UDim2.new(0, 580, 0, 40)
                    or  UDim2.new(0, 580, 0, 400),
            })
        end
        MinBtn.MouseButton1Click:Connect(function() Window:Toggle() end)
        HideBtn.MouseButton1Click:Connect(function() Aquafield:Hide() end)
        CloseBtn.MouseButton1Click:Connect(function()
            saveConfig(Window)
            tween(Main, 0.25, {
                Size                   = UDim2.new(0, 0, 0, 0),
                Position               = UDim2.new(0.5, 0, 0.5, 0),
                BackgroundTransparency = 1,
            })
            task.wait(0.3); ScreenGui:Destroy()
        end)

        -- entrance animation
        Main.Size     = UDim2.new(0, 0, 0, 0)
        Main.Position = UDim2.new(0.5, 0, 0.5, 0)
        spring(Main, 0.45, {
            Size     = UDim2.new(0, 580, 0, 400),
            Position = UDim2.new(0.5, -290, 0.5, -200),
        })
        Window._ready = true
    end

    if opts.KeySystem then
        runKeySystem(opts.KeySettings or {}, th, function() task.spawn(build) end)
    else
        task.spawn(build)
    end

    local timeout = 0
    while not Window._ready and timeout < 30 do
        task.wait(0.05); timeout = timeout + 0.05
    end

