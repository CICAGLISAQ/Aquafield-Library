function Aquafield:Destroy()
    for _, w in ipairs(self.Windows) do
        if w.Screen and w.Screen.Parent then w.Screen:Destroy() end
    end
    if NotifGui then NotifGui:Destroy(); NotifGui = nil; NotifList = nil end
    self.Windows = {}
    self.Flags   = {}
end


