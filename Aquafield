            themed(fbk, "SubText", "text")

            local b = new("ImageButton", {
                Image                  = LUCIDE[kind] or "",
                ImageColor3            = th.SubText,
                ScaleType              = Enum.ScaleType.Fit,
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, -6, 1, -6),
                Position               = UDim2.new(0.5, 0, 0.5, 0),
