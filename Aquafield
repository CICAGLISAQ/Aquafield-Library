-- EASTER EGGS
--   *  Konami code (Up Up Down Down Left Right Left Right B A) -> fireworks
--   *  Typing "matrix" anywhere -> toggles matrix rain overlay
--------------------------------------------------------------------------------
do
    local konami = {
        Enum.KeyCode.Up, Enum.KeyCode.Up,
        Enum.KeyCode.Down, Enum.KeyCode.Down,
        Enum.KeyCode.Left, Enum.KeyCode.Right,
        Enum.KeyCode.Left, Enum.KeyCode.Right,
        Enum.KeyCode.B,    Enum.KeyCode.A,
    }
    local idx = 1
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == konami[idx] then
            idx = idx + 1
            if idx > #konami then
                idx = 1
                local w = Aquafield.Windows[1]
                if w then
                    local s = w.Main.AbsoluteSize
                    for i = 1, 6 do
                        task.delay(i * 0.1, function()
                            Effects.Fireworks(w.Main, math.random() * s.X, math.random() * s.Y, ActiveTheme().AccentGlow)
                        end)
                    end
                end
            end
        else
            idx = 1
        end
    end)

    local typedBuf = ""
    local matrixOn = false
    local matrixHandle
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if UserInputService:GetFocusedTextBox() then return end
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local name = input.KeyCode.Name
            if #name == 1 then
                typedBuf = (typedBuf .. name:lower()):sub(-12)
                if typedBuf:find("matrix") then
                    local w = Aquafield.Windows[1]
                    if w then
                        if matrixOn and matrixHandle then
                            matrixHandle:Destroy(); matrixHandle = nil; matrixOn = false
                        else
                            matrixHandle = Effects.MatrixRain(w.Main, ActiveTheme().Accent, 22)
                            matrixOn = true
                        end
                    end
                end
            end
        end
    end)
end


