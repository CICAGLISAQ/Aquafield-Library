--------------------------------------------------------------------------------
-- ANIMATION PRESETS
--------------------------------------------------------------------------------
local Anim = {}

function Anim.PopIn(obj, finalSize, time)
    obj.Size = UDim2.new(finalSize.X.Scale, 0, finalSize.Y.Scale, 0)
    Util.Tween(obj, time or 0.3, { Size = finalSize }, Enum.EasingStyle.Back)
end

function Anim.FadeIn(obj, time)
    local bt = obj.BackgroundTransparency
    obj.BackgroundTransparency = 1
    Util.Tween(obj, time or 0.25, { BackgroundTransparency = bt })
end

function Anim.SlideInLeft(obj, time)
    local p = obj.Position
    obj.Position = UDim2.new(p.X.Scale - 1, p.X.Offset, p.Y.Scale, p.Y.Offset)
    Util.Tween(obj, time or 0.35, { Position = p }, Enum.EasingStyle.Quint)
end

function Anim.SlideInRight(obj, time)
    local p = obj.Position
    obj.Position = UDim2.new(p.X.Scale + 1, p.X.Offset, p.Y.Scale, p.Y.Offset)
    Util.Tween(obj, time or 0.35, { Position = p }, Enum.EasingStyle.Quint)
end

function Anim.SlideInUp(obj, time)
    local p = obj.Position
    obj.Position = UDim2.new(p.X.Scale, p.X.Offset, p.Y.Scale + 1, p.Y.Offset)
    Util.Tween(obj, time or 0.35, { Position = p }, Enum.EasingStyle.Quint)
end

function Anim.Shake(obj, intensity, duration)
    intensity = intensity or 6
    duration  = duration or 0.3
    local original = obj.Position
    local t0 = tick()
    local conn
    conn = RunService.Heartbeat:Connect(function()
        local dt = tick() - t0
        if dt >= duration then
            obj.Position = original
            conn:Disconnect()
            return
        end
        local p = 1 - (dt / duration)
        obj.Position = UDim2.new(
            original.X.Scale,
            original.X.Offset + (math.random() - 0.5) * intensity * p * 2,
            original.Y.Scale,
            original.Y.Offset + (math.random() - 0.5) * intensity * p * 2
        )
    end)
end

function Anim.Pulse(obj, scale, time)
    scale = scale or 1.08
    time  = time  or 0.18
    local original = obj.Size
    Util.Tween(obj, time, {
        Size = UDim2.new(
            original.X.Scale, original.X.Offset * scale,
            original.Y.Scale, original.Y.Offset * scale
        )
    })
    task.delay(time, function()
        Util.Tween(obj, time, { Size = original })
    end)
end

function Anim.Bounce(obj, height, time)
    height = height or 12
    time   = time   or 0.4
    local original = obj.Position
    local up = UDim2.new(
        original.X.Scale, original.X.Offset,
        original.Y.Scale, original.Y.Offset - height
    )
    Util.Tween(obj, time * 0.4, { Position = up }, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    task.delay(time * 0.4, function()
        Util.Tween(obj, time * 0.6, { Position = original }, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out)
    end)
end

function Anim.Spin(obj, time)
    time = time or 0.4
    Util.Tween(obj, time, { Rotation = obj.Rotation + 360 }, Enum.EasingStyle.Quint)
end

function Anim.FlipX(obj, time)
    time = time or 0.4
    Util.Tween(obj, time / 2, { Size = UDim2.new(0, 0, obj.Size.Y.Scale, obj.Size.Y.Offset) })
    task.delay(time / 2, function()
        Util.Tween(obj, time / 2, { Size = obj.Size })
    end)
end


