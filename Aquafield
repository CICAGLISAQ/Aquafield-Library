        function Tab:CreateDropdown(o)
            local th = Aquafield.Theme
            local options = o.Options or {}
            local multi   = o.MultipleOptions
            local current = multi
                and (type(o.CurrentOption) == "table" and o.CurrentOption or {})
                or (type(o.CurrentOption) == "table" and o.CurrentOption[1] or o.CurrentOption)
            local open = false

            local f = baseElement(36)
            f.ClipsDescendants = true
            local btn = new("TextButton", {
                Text = "", BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 36), Parent = f,
            })
            local lbl = new("TextLabel", {
                Text = o.Name or "Dropdown",
                Font = Enum.Font.GothamMedium, TextSize = 13,
                TextColor3 = th.Text, BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0, 0),
                Size = UDim2.new(0.5, -10, 1, 0),
                TextXAlignment = Enum.TextXAlignment.Left, Parent = btn,
            })
            themed(lbl, "Text", "text")
            local valLbl = new("TextLabel", {
                Font = Enum.Font.Gotham, TextSize = 12,
                TextColor3 = th.Accent, BackgroundTransparency = 1,
                Position = UDim2.new(0.5, 0, 0, 0),
                Size = UDim2.new(0.5, -28, 1, 0),
                TextXAlignment = Enum.TextXAlignment.Right, Parent = btn,
            })
            themed(valLbl, "Accent", "text")
            local arr = new("TextLabel", {
                Text = "▾", Font = Enum.Font.GothamBold, TextSize = 14,
                TextColor3 = th.SubText, BackgroundTransparency = 1,
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -10, 0.5, 0),
                Size = UDim2.new(0, 14, 0, 14), Parent = btn,
            })
            themed(arr, "SubText", "text")

            local listFrame = new("Frame", {
                Size = UDim2.new(1, -20, 0, 0),
                Position = UDim2.new(0, 10, 0, 38),
                BackgroundTransparency = 1, Parent = f,
            })
            new("UIListLayout", { Padding = UDim.new(0, 4), Parent = listFrame })

            local api = {}
            local optionBtns = {}

            local function isSelected(opt)
                if multi then
                    for _, v in ipairs(current) do if v == opt then return true end end
                    return false
                end
                return current == opt
            end

            local function renderValue()
                if multi then
                    valLbl.Text = (#current == 0) and "None" or table.concat(current, ", ")
                else
                    valLbl.Text = tostring(current or "None")
                end
            end

            local function refreshHighlights()
                for opt, b in pairs(optionBtns) do
                    b.TextColor3 = isSelected(opt) and Aquafield.Theme.Accent
                                                   or Aquafield.Theme.SubText
                end
            end

            local function build()
                for _, c in ipairs(listFrame:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                optionBtns = {}
                for _, opt in ipairs(options) do
                    local ob = new("TextButton", {
                        Text = opt, Font = Enum.Font.Gotham, TextSize = 12,
                        TextColor3 = Aquafield.Theme.SubText,
                        BackgroundColor3 = Aquafield.Theme.Background,
                        AutoButtonColor = false,
                        Size = UDim2.new(1, 0, 0, 24), Parent = listFrame,
                    })
                    corner(ob, 4)
                    optionBtns[opt] = ob
                    ob.MouseButton1Click:Connect(function()
                        if multi then
                            local found
                            for i, v in ipairs(current) do
                                if v == opt then found = i break end
                            end
                            if found then table.remove(current, found)
                            else table.insert(current, opt) end
                        else
                            current = opt
                        end
                        api.CurrentOption = current
                        renderValue(); refreshHighlights()
                        if o.Callback then pcall(o.Callback, current) end
                    end)
                end
                refreshHighlights()
            end
            build()

            btn.MouseButton1Click:Connect(function()
                open = not open
                local h = 36 + (open and (#options * 28 + 8) or 0)
                tween(f, 0.2, { Size = UDim2.new(1, 0, 0, h) })
                tween(arr, 0.2, { Rotation = open and 180 or 0 })
            end)

            function api:Set(v) current = v; api.CurrentOption = v
                renderValue(); refreshHighlights()
                if o.Callback then pcall(o.Callback, v) end end
            function api:Refresh(newOpts) options = newOpts; build() end
            api.CurrentOption = current
            renderValue()
            if o.Flag then Aquafield.Flags[o.Flag] = api end
            return api
        end

