            Flag = "AquafieldToggleKeybind",
            Callback = function() end, -- the global listener handles toggling
        })
        -- We want the keybind button to *update the global toggle key*, not just fire a callback.
        -- So we override its Set behaviour and watch when the user picks a new key.
        do
            local origSet = kb.Set
            function kb:Set(k)
                origSet(self, k)
                Aquafield.ToggleUIKeybind = keyCodeFromName(k)
                saveAquafieldPrefs()
            end
        end
        -- Re-route the listening assignment by polling CurrentKeybind
        task.spawn(function()
            local last = kb.CurrentKeybind
            while ScreenGui.Parent do
                task.wait(0.2)
                if kb.CurrentKeybind ~= last then
                    last = kb.CurrentKeybind
                    Aquafield.ToggleUIKeybind = keyCodeFromName(last)
                    saveAquafieldPrefs()
                end
            end
        end)
        Settings:CreateButton({
            Name = "Reset keybind to K",
            Callback = function()
                kb:Set("K")
                Aquafield:Notify({
                    Title = "Keybind reset",
                    Content = "Toggle UI is now bound to K.",
                    Duration = 3,
                })
            end,
        })
        Settings:CreateButton({
            Name = "Hide UI",
            Callback = function() Aquafield:Hide() end,
        })

        Settings:CreateSection("About")
        Settings:CreateParagraph({
            Title = "Aquafield " .. Aquafield._version,
            Content = "Modern, animated Roblox UI library with a Rayfield-compatible API. Press the toggle key (default K) to hide / show this window.",
        })
    end

    if Window.Cfg and Window.Cfg.Enabled then
        task.spawn(function()
            while ScreenGui.Parent do task.wait(10); saveConfig(Window) end
        end)
    end

    pcall(loadAquafieldPrefs)
    table.insert(Aquafield._windows, Window)
    return Window
end -- CreateWindow

