-- THEME UTILITIES  ::  per-theme tint generators
--------------------------------------------------------------------------------
function Aquafield.TintFor(themeName)
    local t = Themes[themeName] or ActiveTheme()
    return {
        Soft  = Util.Lighten(t.Accent, 0.12),
        Hard  = Util.Darken(t.Accent, 0.18),
        Halo  = Util.Lighten(t.AccentGlow, 0.05),
        Ghost = Color3.new(t.Accent.R * 0.5, t.Accent.G * 0.5, t.Accent.B * 0.5),
    }
end

function Aquafield.AccentSequence(themeName)
    local t = Themes[themeName] or ActiveTheme()
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0,   t.AccentGlow),
        ColorSequenceKeypoint.new(0.5, t.Accent),
        ColorSequenceKeypoint.new(1,   t.AccentSoft),
    })
end

