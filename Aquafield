                    ZIndex = 3,
                    Parent = ddFrame,
                })
                
                local selectBtn = new("TextButton", {
                    Text = currentVal .. " ▾",
                    Font = Enum.Font.GothamMedium,
                    TextSize = 12,
                    TextColor3 = th.Accent,
                    BackgroundColor3 = th.Element,
                    BackgroundTransparency = 0.2,
                    BorderSizePixel = 0,
                    Position = UDim2.new(1, -70, 0.5, -12),
                    Size = UDim2.new(0, 60, 0, 24),
                    ZIndex = 3,
                    Parent = ddFrame,
                })
                corner(selectBtn, 6)
                stroke(selectBtn, th.ElementBorder, 1, 0.4)
                
                local dropdownList = new("Frame", {
                    Size = UDim2.new(1, -20, 0, 0),
                    Position = UDim2.new(0, 10, 0, 40),
                    BackgroundColor3 = th.Sidebar,
                    BackgroundTransparency = 0.1,
                    BorderSizePixel = 0,
                    ZIndex = 5,
                    Visible = false,
                    Parent = ddFrame,
                })
                corner(dropdownList, 6)
                stroke(dropdownList, th.ElementBorder, 1, 0.3)
                local ddLayout = listLayout(dropdownList, 2)
                padding(dropdownList, 4, 4, 4, 4)
                
                local function populateDropdown()
                    for _, child in ipairs(dropdownList:GetChildren()) do
                        if child:IsA("TextButton") then child:Destroy() end
                    end
                    for _, opt in ipairs(options) do
                        local optBtn = new("TextButton", {
                            Text = opt,
                            Font = Enum.Font.GothamMedium,
                            TextSize = 12,
                            TextColor3 = th.Text,
                            BackgroundColor3 = opt == currentVal and th.Accent or th.Element,
                            BackgroundTransparency = opt == currentVal and 0.3 or 0.4,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 0, 24),
                            ZIndex = 6,
                            Parent = dropdownList,
                        })
                        corner(optBtn, 4)
                        optBtn.MouseEnter:Connect(function()
                            tween(optBtn, 0.15, {BackgroundTransparency = 0.1})
                        end)
                        optBtn.MouseLeave:Connect(function()
                            tween(optBtn, 0.2, {BackgroundTransparency = opt == currentVal and 0.3 or 0.4})
                        end)
                        optBtn.MouseButton1Click:Connect(function()
                            currentVal = opt
                            selectBtn.Text = opt .. " ▾"
                            open = false
                            dropdownList.Visible = false
                            tween(ddFrame, 0.25, {Size = UDim2.new(1, 0, 0, 36)})
                            if o.Callback then pcall(o.Callback, opt) end
                        end)
                    end
                    dropdownList.Size = UDim2.new(1, -20, 0, #options * 26 + 8)
                end
                populateDropdown()
                
                selectBtn.MouseButton1Click:Connect(function()
                    open = not open
                    dropdownList.Visible = open
                    if open then
                        local targetHeight = 44 + dropdownList.AbsoluteSize.Y
                        tween(ddFrame, 0.3, {Size = UDim2.new(1, 0, 0, targetHeight)}, Enum.EasingStyle.Quad)
                    else
                        tween(ddFrame, 0.25, {Size = UDim2.new(1, 0, 0, 36)})
                    end
                end)
                
                resizeSection()
                local api = { CurrentValue = currentVal }
                function api:Set(val)
                    currentVal = val
                    selectBtn.Text = val .. " ▾"
                    api.CurrentValue = val
                    populateDropdown()
                end
                function api:Refresh(newOpts)
                    options = newOpts
                    currentVal = options[1] or ""
                    selectBtn.Text = currentVal .. " ▾"
                    populateDropdown()
                    api.CurrentValue = currentVal
                end
                if o.Flag then Aquafield.Flags[o.Flag] = api; Aquafield.Flags[o.Flag].CurrentValue = currentVal end
                return api
            end
            
            function sec:CreateParagraph(o)
                local pFrame = new("Frame", {
                    Size = UDim2.new(1, 0, 0, 0),
                    BackgroundTransparency = 1,
                    AutomaticSize = Enum.AutomaticSize.Y,
                    LayoutOrder = #sectionContent:GetChildren(),
                    Parent = sectionContent,
                })
                
                local pText = new("TextLabel", {
                    Text = o.Text or o.Name or "",
                    Font = Enum.Font.GothamMedium,
                    TextSize = 12,
                    TextColor3 = th.SubText,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -20, 0, 0),
                    Position = UDim2.new(0, 10, 0, 4),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    RichText = true,
                    AutomaticSize = Enum.AutomaticSize.Y,
                    ZIndex = 3,
                    Parent = pFrame,
                })
                
                task.wait()
                pFrame.Size = UDim2.new(1, 0, 0, pText.TextBounds.Y + 8)
                
                resizeSection()
                local api = { CurrentValue = pText.Text }
                function api:Set(t) pText.Text = t; api.CurrentValue = t end
                return api
            end
            
            return sec
        end
        
        return tabData
    end
    
    -- Load configuration if enabled
    if win.Cfg and win.Cfg.Enabled then
        task.spawn(function()
            task.wait(0.5)
            pcall(loadConfig, win)
        end)
    end
    
    return win
end

-- ============================================================================
-- LOAD CONFIGURATION
-- ============================================================================
function Aquafield:LoadConfiguration()
    for _, win in ipairs(self._windows) do
        if win.Cfg and win.Cfg.Enabled then
            pcall(loadConfig, win)
        end
    end
end

-- ============================================================================
-- SET TOGGLE KEY
-- ============================================================================
function Aquafield:SetToggleKey(keyCode)
    if type(keyCode) == "string" then
        self.ToggleKey = Enum.KeyCode[keyCode]
    else
        self.ToggleKey = keyCode
    end
end

-- ============================================================================
-- GET FLAGS
-- ============================================================================
function Aquafield:GetFlags()
    return self.Flags
end

-- ============================================================================
-- ALERT / NOTIFICATION
-- ============================================================================
function Aquafield:Notify(o)
    local title = o.Title or "Notification"
    local content_text = o.Content or ""
    local duration = o.Duration or 3
    local th = Themes.Ocean
    
    local notifContainer = new("Frame", {
        Size = UDim2.new(0, 320, 0, 0),
        Position = UDim2.new(1, -340, 0, 20),
        BackgroundColor3 = th.Background,
        BackgroundTransparency = 0.1,
        BorderSizePixel = 0,
        ZIndex = 100,
        ClipsDescendants = true,
        Parent = ScreenGui,
    })
    corner(notifContainer, 8)
    stroke(notifContainer, th.GlassBorder, 1, 0.4)
    createGlassEffect(notifContainer, th)
    
    -- Title
    new("TextLabel", {
        Text = title,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = th.Accent,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 8),
        Size = UDim2.new(1, -24, 0, 20),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 101,
        Parent = notifContainer,
    })
    
    -- Content
    local contentLbl = new("TextLabel", {
        Text = content_text,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = th.SubText,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 30),
        Size = UDim2.new(1, -24, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        AutomaticSize = Enum.AutomaticSize.Y,
        ZIndex = 101,
        Parent = notifContainer,
    })
    
    task.wait()
    local totalHeight = contentLbl.TextBounds.Y + 40
    notifContainer.Size = UDim2.new(0, 320, 0, 0)
    
    -- Animate in
    tween(notifContainer, 0.4, {Size = UDim2.new(0, 320, 0, totalHeight)}, Enum.EasingStyle.Back)
    notifContainer.Position = UDim2.new(1, -340, 0, 20)
    tween(notifContainer, 0.4, {
        Position = UDim2.new(1, -340, 0, 20 + 10 * #self._windows),
    }, Enum.EasingStyle.Quad)
    
    -- Auto remove
    task.delay(duration, function()
        tween(notifContainer, 0.3, {
            Position = UDim2.new(1, 20, 0, 20),
            BackgroundTransparency = 1,
        }, Enum.EasingStyle.Quad)
        task.delay(0.3, function() notifContainer:Destroy() end)
    end)
end

-- ============================================================================
-- DESTROY
-- ============================================================================
function Aquafield:Destroy()
    for _, win in ipairs(self._windows) do
        if win._particleConnection then
            win._particleConnection:Disconnect()
        end
    end
    if ScreenGui and ScreenGui.Parent then
        ScreenGui:Destroy()
    end
end

return Aquafield
