            TextColor3       = th.Text,
            BackgroundTransparency = 1,
            Position         = UDim2.new(0, titleX, 0, 0),
            Size             = UDim2.new(0.7, 0, 1, 0),
            TextXAlignment   = Enum.TextXAlignment.Left,
            Parent           = Top,
        })
        themed(Title, "Text", "text")

        --------------------------------------------------------------
        -- TOPBAR ICON BUTTONS  (lucide-roblox image assets)
        --   Replaces the previous garbled UTF-8 glyphs that the
        --   GothamBold font could not render.  Each button is now an
        --   ImageButton backed by a lucide icon asset, with a glowing
        --   accent halo on hover and a soft scale feedback on press.
        --   A unicode fallback label is layered underneath for cases
        --   where the executor cannot stream the image asset.
        --
        --   Lucide icon assets (lucide-roblox / Sirius):
        --     X       (close)     -> rbxassetid://10747384394
        --     Minus   (minimize)  -> rbxassetid://10734950309
        --     EyeOff  (hide)      -> rbxassetid://10747384376
        --------------------------------------------------------------
        local LUCIDE = {
            close    = "rbxassetid://10747384394",
            minimize = "rbxassetid://10734950309",
            hide     = "rbxassetid://10747384376",
        }
        local FALLBACK_TEXT = {
            close    = "\u{2715}",  -- glyph X
            minimize = "\u{2212}",  -- glyph minus
            hide     = "\u{25C9}",  -- glyph fish-eye
        }

