            function sec:CreateSlider(o)
                local sliderFrame = new("Frame", {
                    Size = UDim2.new(1, 0, 0, 48),
                    BackgroundTransparency = 1,
                    LayoutOrder = #sectionContent:GetChildren(),
                    Parent = sectionContent,
                })
                
                local min = o.Min or 0
                local max = o.Max or 100
                local val = o.CurrentValue or 0
                local precise = o.Precise or false
                local suffix = o.Suffix or ""
                
                local label = new("TextLabel", {
                    Text = o.Name or "Slider",
                    Font = Enum.Font.GothamMedium,
                    TextSize = 13,
                    TextColor3 = th.Text,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 4),
                    Size = UDim2.new(1, -80, 0, 18),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 3,
                    Parent = sliderFrame,
                })
                
                local valueLabel = new("TextLabel", {
                    Text = tostring(precise and math.floor(val * 10) / 10 or math.floor(val)) .. suffix,
                    Font = Enum.Font.GothamBold,
                    TextSize = 12,
                    TextColor3 = th.Accent,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -70, 0, 4),
                    Size = UDim2.new(0, 60, 0, 18),
                    TextXAlignment = Enum.TextXAlignment.Right,
                    ZIndex = 3,
                    Parent = sliderFrame,
                })
                
                local barBg = new("Frame", {
                    Size = UDim2.new(1, -20, 0, 6),
                    Position = UDim2.new(0, 10, 0, 32),
                    BackgroundColor3 = th.ElementBorder,
                    BackgroundTransparency = 0.5,
                    BorderSizePixel = 0,
                    ZIndex = 3,
                    Parent = sliderFrame,
                })
                corner(barBg, 3)
                
                local barFill = new("Frame", {
                    Size = UDim2.new((val - min) / (max - min), 0, 1, 0),
                    BackgroundColor3 = th.Accent,
                    BackgroundTransparency = 0,
                    BorderSizePixel = 0,
                    ZIndex = 4,
                    Parent = barBg,
                })
                corner(barFill, 3)
                
                local drag = false
                local function updateSlider(input)
                    local rel = (input.Position.X - barBg.AbsolutePosition.X) / barBg.AbsoluteSize.X
                    rel = math.clamp(rel, 0, 1)
                    local newVal = min + (max - min) * rel
                    if not precise then newVal = math.floor(newVal) end
                    val = newVal
                    barFill.Size = UDim2.new(rel, 0, 1, 0)
                    valueLabel.Text = tostring(precise and math.floor(val * 10) / 10 or math.floor(val)) .. suffix
                    if o.Callback then pcall(o.Callback, val) end
                end
                
                barBg.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 or
                       i.UserInputType == Enum.UserInputType.Touch then
                        drag = true
                        updateSlider(i)
                    end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 or
                       i.UserInputType == Enum.UserInputType.Touch then
                        drag = false
                    end
                end)
                UserInputService.InputChanged:Connect(function(i)
                    if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or
                                i.UserInputType == Enum.UserInputType.Touch) then
                        updateSlider(i)
                    end
                end)
                
                resizeSection()
                local api = { CurrentValue = val }
                function api:Set(newVal)
                    val = newVal
                    local rel = (val - min) / (max - min)
                    barFill.Size = UDim2.new(rel, 0, 1, 0)
                    valueLabel.Text = tostring(precise and math.floor(val * 10) / 10 or math.floor(val)) .. suffix
                    api.CurrentValue = val
                end
                if o.Flag then Aquafield.Flags[o.Flag] = api; Aquafield.Flags[o.Flag].CurrentValue = val end
                return api
            end
            
