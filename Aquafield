        themed(SearchBox, "SubText", "placeholder")

        -- focus pulse: glowing border ring when the box has focus
        do
            local ring = new("UIStroke", {
                Color        = th.Accent,
                Thickness    = 1,
                Transparency = 1,
                Parent       = SearchHolder,
