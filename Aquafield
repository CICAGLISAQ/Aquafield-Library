-- HOTKEY TABLE  ::  renders a list of {key, action} pairs
--------------------------------------------------------------------------------
function ExtraComponents.HotkeyTable(page, entries)
    local theme = ActiveTheme()
    local shell = Util.New("Frame", {
        Size                   = UDim2.new(1, 0, 0, 24 + #entries * 22),
        BackgroundColor3       = theme.Element,
        BackgroundTransparency = 0.05,
        BorderSizePixel        = 0,
        Parent                 = page,
    })
    Util.Corner(shell, 8)
    Util.Stroke(shell, theme.Border, 1, 0.5)
    for i, e in ipairs(entries) do
        local row = Util.New("Frame", {
            Position               = UDim2.new(0, 12, 0, 12 + (i - 1) * 22),
            Size                   = UDim2.new(1, -24, 0, 20),
            BackgroundTransparency = 1,
            Parent                 = shell,
        })
        local k = Util.New("TextLabel", {
            Size                   = UDim2.new(0.3, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                   = e[1],
            Font                   = Enum.Font.Code,
            TextSize               = 12,
            TextColor3             = theme.Accent,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Parent                 = row,
        })
        local a = Util.New("TextLabel", {
            Position               = UDim2.new(0.32, 0, 0, 0),
            Size                   = UDim2.new(0.68, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                   = e[2],
            Font                   = Enum.Font.Gotham,
            TextSize               = 12,
            TextColor3             = theme.Text,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Parent                 = row,
        })
    end
    return shell
end


