--==============================================================
-- AMBIENT PARTICLE FIELD  (background life)
--==============================================================
local function buildParticleField(parent, count, theme)
    local field = create("Frame", {
        Name = "Particles",
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),
        ZIndex = 1,
        Parent = parent,
        ClipsDescendants = true,
    })
    local list = {}
    for i = 1, count or 14 do
        local p = create("Frame", {
            BackgroundColor3 = theme.AccentGlow,
            BackgroundTransparency = 0.7,
            BorderSizePixel = 0,
            Size = UDim2.fromOffset(math.random(2, 5), math.random(2, 5)),
            Position = UDim2.fromScale(math.random(), math.random()),
            Parent = field,
        })
        corner(p, 8)
        table.insert(list, { obj = p, vy = -math.random(2, 9)/100, drift = (math.random()-0.5)/200 })
    end
    RunService.RenderStepped:Connect(function()
        for _, e in ipairs(list) do
            local pos = e.obj.Position
            local ny = pos.Y.Scale + e.vy * 0.6
            local nx = pos.X.Scale + e.drift
            if ny < -0.05 then ny = 1.05 end
            if nx < -0.05 then nx = 1.05 elseif nx > 1.05 then nx = -0.05 end
            e.obj.Position = UDim2.fromScale(nx, ny)
        end
    end)
    return field
end


