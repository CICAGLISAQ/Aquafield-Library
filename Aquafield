local function positionNotifHolder(side)
    Aquafield.NotifSide = side or Aquafield.NotifSide
    local layout = NotifHolder:FindFirstChildOfClass("UIListLayout")
    if side == "BottomLeft" then
        NotifHolder.AnchorPoint = Vector2.new(0, 1)
        NotifHolder.Position    = UDim2.new(0, 20, 1, -20)
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
        layout.VerticalAlignment   = Enum.VerticalAlignment.Bottom
    elseif side == "TopRight" then
        NotifHolder.AnchorPoint = Vector2.new(1, 0)
        NotifHolder.Position    = UDim2.new(1, -20, 0, 20)
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
        layout.VerticalAlignment   = Enum.VerticalAlignment.Top
    elseif side == "TopLeft" then
        NotifHolder.AnchorPoint = Vector2.new(0, 0)
        NotifHolder.Position    = UDim2.new(0, 20, 0, 20)
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
        layout.VerticalAlignment   = Enum.VerticalAlignment.Top
    else
        NotifHolder.AnchorPoint = Vector2.new(1, 1)
        NotifHolder.Position    = UDim2.new(1, -20, 1, -20)
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
        layout.VerticalAlignment   = Enum.VerticalAlignment.Bottom
    end
end

function Aquafield:Notify(opts)
    opts = opts or {}
    local title    = opts.Title    or "Notification"
    local content  = opts.Content  or ""
    local duration = opts.Duration or 4
    local image    = opts.Image
    local th       = Aquafield.Theme

    if typeof(image) == "number" then
        image = "rbxassetid://" .. tostring(image)
    end

    local card = new("Frame", {
        Size                  = UDim2.new(1, 0, 0, 78),
        BackgroundColor3      = th.Sidebar,
        BackgroundTransparency= 0.05,
        Position              = UDim2.new(1, 80, 0, 0),
        Parent                = NotifHolder,
    })
    corner(card, 12)
    stroke(card, th.Border, 1, 0.4)
    themed(card, "Sidebar")

    -- glow gradient overlay
    local glow = new("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = th.Accent,
        BackgroundTransparency = 0.92,
        BorderSizePixel = 0,
        Parent = card,
    })
    corner(glow, 12); themed(glow, "Accent")
