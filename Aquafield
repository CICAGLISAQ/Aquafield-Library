-- AMBIENT PARTICLE FIELD  (decorative, very light cost)
local ParticleLayer
local Particles = {}

local function spawnParticle(parent)
    local th = Aquafield.Theme
    local size = math.random(2, 5)
    local p = new("Frame", {
        Size               = UDim2.new(0, size, 0, size),
        Position           = UDim2.new(math.random(), 0, 1, 20),
        BackgroundColor3   = th.Accent,
        BackgroundTransparency = 0.6 + math.random() * 0.3,
        BorderSizePixel    = 0,
        Parent             = parent,
    })
    corner(p, size)
    themed(p, "Accent")
    local duration = math.random(60, 140) / 10
    local xDrift   = (math.random() - 0.5) * 0.1
    tween(p, duration, {
        Position             = UDim2.new(math.clamp(p.Position.X.Scale + xDrift, 0, 1), 0, 0, -20),
        BackgroundTransparency = 1,
    }, Enum.EasingStyle.Linear)
    task.delay(duration, function() if p then p:Destroy() end end)
end

local function startParticleField(parent)
    ParticleLayer = new("Frame", {
        Name             = "Particles",
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex           = 0,
        Parent           = parent,
    })
    task.spawn(function()
        while ParticleLayer and ParticleLayer.Parent do
            task.wait(0.35)
            if #Particles < 40 and not Aquafield._hidden then
                spawnParticle(ParticleLayer)
            end
        end
    end)
end

-- FX ENGINE  (animated theme gradients, breathing halos, shimmer sweeps)
--   The FX engine is a single RunService.Heartbeat loop that walks a
--   registry of "animated layers" and updates them every frame.  Layers
--   are registered through Aquafield._fxRegister(kind, inst, opts) and
--   are torn down automatically when their instance is destroyed.
--
--   Supported layer kinds:
--     * "rotate"   -> spins a UIGradient at a constant rate
--     * "breathe"  -> oscillates BackgroundTransparency on a sine wave
--     * "shimmer"  -> sweeps a bright UIGradient across the host
--     * "pulse"    -> oscillates Size around a base size
--     * "drift"    -> oscillates Position around a base position
--     * "rainbow"  -> cycles a UIGradient through the active theme stops
--
--   Performance: a single Heartbeat connection drives all layers, with
--   automatic culling of destroyed hosts.  Cost on a typical window
--   (~6 layers) is well under 0.05ms / frame on modern hardware.
Aquafield._fxLayers = {}

local function fxRegister(kind, inst, opts)
    opts = opts or {}
    local layer = {
        kind  = kind,
        inst  = inst,
        opts  = opts,
        t0    = os.clock(),
        alive = true,
    }
    Aquafield._fxLayers[#Aquafield._fxLayers + 1] = layer
    return layer
end
Aquafield._fxRegister = fxRegister

local function fxAccentTrio()
    local th = Aquafield.Theme
    return th.AccentA or th.Accent,
           th.AccentB or th.AccentSoft or th.Accent,
           th.AccentC or th.Accent
end

local function fxBgTrio()
    local th = Aquafield.Theme
    return th.BgGradientA or th.Background,
           th.BgGradientB or th.Sidebar,
           th.BgGradientC or th.Element
end

RunService.Heartbeat:Connect(function(dt)
    if Aquafield._hidden then return end
    local now   = os.clock()
    local live  = {}
    for _, layer in ipairs(Aquafield._fxLayers) do
        local inst = layer.inst
        if inst and inst.Parent then
            local t = now - layer.t0
            local o = layer.opts
            if layer.kind == "rotate" then
                local speed = o.speed or 24
                if inst:IsA("UIGradient") then
                    inst.Rotation = (inst.Rotation + dt * speed) % 360
                end
            elseif layer.kind == "breathe" then
                local lo    = o.lo    or 0.85
                local hi    = o.hi    or 0.95
                local speed = o.speed or 1.4
                local a     = (math.sin(t * speed) + 1) * 0.5
                inst.BackgroundTransparency = lo + (hi - lo) * a
            elseif layer.kind == "shimmer" then
                local speed = o.speed or 0.6
                if inst:IsA("UIGradient") then
                    local k = (t * speed) % 1
                    inst.Offset = Vector2.new(-1 + 2 * k, 0)
                end
            elseif layer.kind == "pulse" then
                local base   = o.base or UDim2.new(1, 0, 1, 0)
                local amp    = o.amp or 0.04
                local speed  = o.speed or 1.2
                local s      = 1 + math.sin(t * speed) * amp
                inst.Size = UDim2.new(
                    base.X.Scale * s, base.X.Offset,
                    base.Y.Scale * s, base.Y.Offset)
            elseif layer.kind == "drift" then
                local base  = o.base or inst.Position
                local ampX  = o.ampX or 2
                local ampY  = o.ampY or 2
                local speed = o.speed or 0.8
                inst.Position = UDim2.new(
                    base.X.Scale, base.X.Offset + math.cos(t * speed) * ampX,
                    base.Y.Scale, base.Y.Offset + math.sin(t * speed) * ampY)
            elseif layer.kind == "rainbow" then
                if inst:IsA("UIGradient") then
                    local a, b, c = fxAccentTrio()
                    local k = (math.sin(t * (o.speed or 0.7)) + 1) * 0.5
                    local c1 = lerpColor(a, c, k)
                    local c2 = lerpColor(b, a, k)
                    inst.Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0,   c1),
                        ColorSequenceKeypoint.new(0.5, c2),
                        ColorSequenceKeypoint.new(1,   c1),
                    })
                end
            elseif layer.kind == "themedRotate" then
                if inst:IsA("UIGradient") then
                    inst.Rotation = (inst.Rotation + dt * (o.speed or 18)) % 360
                    local a, b, c = fxBgTrio()
                    inst.Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, a),
                        ColorSequenceKeypoint.new(0.5, b),
                        ColorSequenceKeypoint.new(1, c),
                    })
                end
            end
            live[#live + 1] = layer
        end
    end
    Aquafield._fxLayers = live
end)

-- Convenience FX builders used by the window builder ----------------------
local function fxBreathe(inst, lo, hi, speed)
    return fxRegister("breathe", inst, { lo = lo, hi = hi, speed = speed })
end

local function fxRotateGradient(uigrad, speed)
    return fxRegister("rotate", uigrad, { speed = speed })
end

local function fxThemedRotate(uigrad, speed)
    return fxRegister("themedRotate", uigrad, { speed = speed })
end

local function fxRainbow(uigrad, speed)
    return fxRegister("rainbow", uigrad, { speed = speed })
end

local function fxShimmer(uigrad, speed)
    return fxRegister("shimmer", uigrad, { speed = speed })
end

local function fxPulse(inst, amp, speed, base)
    return fxRegister("pulse", inst, { amp = amp, speed = speed, base = base })
end

local function fxDrift(inst, ax, ay, speed, base)
    return fxRegister("drift", inst, { ampX = ax, ampY = ay, speed = speed, base = base })
end

-- Build a 3-stop themed gradient that lives on `parent`, returns the UIGradient
local function buildThemedGradient(parent, rotation)
    local a, b, c = fxBgTrio()
    local g = new("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   a),
            ColorSequenceKeypoint.new(0.5, b),
            ColorSequenceKeypoint.new(1,   c),
        }),
        Rotation = rotation or 35,
        Parent   = parent,
    })
    return g
end

-- Build a shimmer gradient (white → transparent → white) for sweep effect
local function buildShimmerGradient(parent)
    local s = new("UIGradient", {
        Color = ColorSequence.new(Color3.fromRGB(255,255,255)),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0,   1),
            NumberSequenceKeypoint.new(0.45, 0.85),
            NumberSequenceKeypoint.new(0.5,  0.6),
            NumberSequenceKeypoint.new(0.55, 0.85),
            NumberSequenceKeypoint.new(1,   1),
        }),
        Rotation = 25,
        Parent = parent,
    })
    return s
end

