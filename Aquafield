        Parent = notif,
    })
    
    -- Title
    local title = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -30, 0, 22),
        Position = UDim2.new(0, 15, 0, 12),
        Font = Enum.Font.GothamSemibold,
        Text = notificationData.Title or "Notification",
        TextColor3 = notifTheme.TextColor,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notif,
    })
    
    -- Close button
    local closeBtn = self:Create("ImageButton", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -30, 0, 12),
        Image = "rbxassetid://6031094678",
        ImageColor3 = Color3.fromRGB(150, 150, 160),
        Parent = notif,
    })
    
    -- Content
    local content = notificationData.Content or ""
    local textSize = self:GetTextSize(content, Enum.Font.Gotham, 14, 350)
    
    local contentLabel = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -30, 0, math.max(textSize.Y + 5, 20)),
        Position = UDim2.new(0, 15, 0, 38),
        Font = Enum.Font.Gotham,
        Text = content,
        TextColor3 = notifTheme.SubTextColor,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = notif,
    })
    
    -- Duration bar
    local duration = notificationData.Duration or 5
    local barContainer = self:Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(40, 40, 50),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 3),
        Position = UDim2.new(0, 0, 1, -3),
        Parent = notif,
    })
    
    local bar = self:Create("Frame", {
        BackgroundColor3 = notifTheme.BorderColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = barContainer,
    })
    
    -- Actions
    local actions = notificationData.Actions
    local actionButtons = {}
    local buttonStartY = 38 + contentLabel.Size.Y.Offset + 8
    
    if actions and #actions > 0 then
        for i, action in ipairs(actions) do
            local btn = self:Create("TextButton", {
                BackgroundColor3 = elemTheme.BackgroundColor,
                BorderSizePixel = 0,
                Size = UDim2.new(0.5, -20, 0, 30),
                Position = UDim2.new(0, 15 + ((i-1) * (0.5)), 0, buttonStartY),
                Font = Enum.Font.GothamSemibold,
                Text = action.Name or "Action",
                TextColor3 = notifTheme.TextColor,
                TextSize = 14,
                Parent = notif,
            })
            
            local btnUICorner = self:Create("UICorner", {
                CornerRadius = UDim.new(0, 6),
                Parent = btn,
            })
            
            btn.MouseEnter:Connect(function()
                self:TweenObject(btn, {BackgroundColor3 = Color3.fromRGB(35, 35, 45)}, TweenInfo.new(0.15))
            end)
            btn.MouseLeave:Connect(function()
                self:TweenObject(btn, {BackgroundColor3 = elemTheme.BackgroundColor}, TweenInfo.new(0.15))
            end)
            btn.MouseButton1Click:Connect(function()
                if action.Callback then
                    action.Callback()
                end
                self:DestroyNotification(notif)
            end)
            
            table.insert(actionButtons, btn)
        end
    end
    
    -- Calculate total height
    local totalHeight = buttonStartY + (#actionButtons > 0 and 38 or 0) + 3
    notif.Size = UDim2.new(0, 380, 0, totalHeight + 10)
    
    -- Animate in
    notif.BackgroundTransparency = 1
    title.TextTransparency = 1
    contentLabel.TextTransparency = 1
    border.BackgroundTransparency = 1
    for _, btn in ipairs(actionButtons) do
        btn.BackgroundTransparency = 1
        btn.TextTransparency = 1
    end
    
    notif.Size = UDim2.new(0, 380, 0, 0)
    self:TweenObject(notif, {Size = UDim2.new(0, 380, 0, totalHeight + 10)}, TweenInfo.new(0.4, Enum.EasingStyle.Quint))
    self:TweenObject(notif, {BackgroundTransparency = 0}, TweenInfo.new(0.3))
    self:TweenObject(title, {TextTransparency = 0}, TweenInfo.new(0.3))
    self:TweenObject(contentLabel, {TextTransparency = 0}, TweenInfo.new(0.35))
    self:TweenObject(border, {BackgroundTransparency = 0}, TweenInfo.new(0.3))
    for _, btn in ipairs(actionButtons) do
        self:TweenObject(btn, {BackgroundTransparency = 0}, TweenInfo.new(0.35))
        self:TweenObject(btn, {TextTransparency = 0}, TweenInfo.new(0.4))
    end
    
    -- Animate duration bar
    if duration > 0 then
        self:TweenObject(bar, {Size = UDim2.new(0, 0, 1, 0)}, TweenInfo.new(duration, Enum.EasingStyle.Linear))
    end
    
    -- Close button
    closeBtn.MouseButton1Click:Connect(function()
        self:DestroyNotification(notif)
    end)
    
    -- Auto destroy
    if duration > 0 then
        task.delay(duration, function()
            if notif and notif.Parent then
                self:DestroyNotification(notif)
            end
        end)
    end
    
    return notif
end

function ShadowField:DestroyNotification(notif)
    if not notif or not notif.Parent then return end
    self:TweenObject(notif, {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 380, 0, 0)
    }, TweenInfo.new(0.3, Enum.EasingStyle.Quint))
    
    for _, v in ipairs(notif:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") then
            self:TweenObject(v, {TextTransparency = 1}, TweenInfo.new(0.2))
        elseif v:IsA("Frame") or v:IsA("ImageButton") then
            self:TweenObject(v, {BackgroundTransparency = 1}, TweenInfo.new(0.2))
        end
    end
    
    task.delay(0.3, function()
        pcall(function() notif:Destroy() end)
    end)
end

