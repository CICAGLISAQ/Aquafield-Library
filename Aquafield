-- ============================

function ShadowField:CreateSlider(window, section, sliderConfig)
    local theme = window.Theme
    local elemTheme = theme.Element
    
    local min = sliderConfig.Min or 0
    local max = sliderConfig.Max or 100
    local decimals = sliderConfig.Decimals or 1
    local defaultValue = sliderConfig.Default or min
    
    -- Load saved
    if window.SavedData and sliderConfig.Name then
        local saved = window.SavedData[sliderConfig.Name]
        if saved ~= nil then
            defaultValue = saved
        end
    end
    
    local currentValue = math.clamp(defaultValue, min, max)
    
    local sliderFrame = self:Create("Frame", {
        BackgroundColor3 = elemTheme.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 50),
        Parent = section.ElementsContainer,
    })
    
    local sliderCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = sliderFrame,
    })
    
    -- Label
    local label = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 0, 20),
        Position = UDim2.new(0, 12, 0, 6),
        Font = Enum.Font.Gotham,
        Text = sliderConfig.Name or "Slider",
        TextColor3 = elemTheme.TextColor,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = sliderFrame,
    })
    
    -- Value display
    local valueLabel = self:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 50, 0, 20),
        Position = UDim2.new(1, -55, 0, 6),
        Font = Enum.Font.GothamSemibold,
        Text = tostring(ShadowField:RoundNumber(currentValue, decimals)),
        TextColor3 = theme.Window.AccentColor,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = sliderFrame,
    })
    
    -- Slider track
    local sliderTrack = self:Create("Frame", {
        BackgroundColor3 = elemTheme.SliderBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -24, 0, 6),
        Position = UDim2.new(0, 12, 0, 34),
        Parent = sliderFrame,
    })
    
    local trackCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 3),
        Parent = sliderTrack,
    })
    
    -- Slider fill
    local sliderFill = self:Create("Frame", {
        BackgroundColor3 = elemTheme.SliderFill,
        BorderSizePixel = 0,
        Size = UDim2.new((currentValue - min) / (max - min), 0, 1, 0),
        Parent = sliderTrack,
    })
    
    local fillCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 3),
        Parent = sliderFill,
    })
    
    -- Slider knob
    local sliderKnob = self:Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new((currentValue - min) / (max - min), -7, 0.5, -7),
        Parent = sliderTrack,
    })
    
    local knobCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 7),
        Parent = sliderKnob,
    })
    
    local dragging = false
    
    local function UpdateSlider(input)
        local trackPos = sliderTrack.AbsolutePosition
        local trackSize = sliderTrack.AbsoluteSize
        local mouseX = input.Position.X
        
        local percent = (mouseX - trackPos.X) / trackSize.X
        percent = math.clamp(percent, 0, 1)
        
        local newValue = min + (max - min) * percent
        newValue = ShadowField:RoundNumber(newValue, decimals)
        currentValue = math.clamp(newValue, min, max)
        
        -- Update UI
        sliderFill.Size = UDim2.new((currentValue - min) / (max - min), 0, 1, 0)
        sliderKnob.Position = UDim2.new((currentValue - min) / (max - min), -7, 0.5, -7)
        valueLabel.Text = tostring(currentValue)
        
        -- Save
        if sliderConfig.Name and window.ConfigSave.Enabled then
            window.SavedData[sliderConfig.Name] = currentValue
            ShadowField:SaveConfiguration(
                window.ConfigSave.FolderName,
                window.ConfigSave.FileName,
                window.SavedData
            )
        end
    end
    
    local function FinishSlider()
        dragging = false
        if sliderConfig.Callback then
            pcall(sliderConfig.Callback, currentValue)
        end
    end
    
    sliderTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            UpdateSlider(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            FinishSlider()
        end
    end)
    
    -- Hover
    sliderFrame.MouseEnter:Connect(function()
        self:TweenObject(sliderFrame, {
            BackgroundColor3 = elemTheme.HoverColor,
        }, TweenInfo.new(0.15))
    end)
    sliderFrame.MouseLeave:Connect(function()
        self:TweenObject(sliderFrame, {
            BackgroundColor3 = elemTheme.BackgroundColor,
        }, TweenInfo.new(0.15))
    end)
    
    section.UpdateSize()
    
    -- Fire initial callback
    if sliderConfig.Callback then
        task.spawn(sliderConfig.Callback, currentValue)
    end
    
    return {
        Frame = sliderFrame,
        
        Set = function(self, value)
            currentValue = math.clamp(value, min, max)
            sliderFill.Size = UDim2.new((currentValue - min) / (max - min), 0, 1, 0)
            sliderKnob.Position = UDim2.new((currentValue - min) / (max - min), -7, 0.5, -7)
            valueLabel.Text = tostring(currentValue)
        end,
        
        Get = function(self)
            return currentValue
        end,
        
        SetCallback = function(self, cb)
            sliderConfig.Callback = cb
        end,
        
        Destroy = function(self)
            sliderFrame:Destroy()
            section.UpdateSize()
        end,
    }
end

