local ParticleLayer
local Particles = {}

local function spawnParticle(parent)
    local th = Aquafield.Theme
    local size = math.random(2, 5)
    local p = new("Frame", {
        Size               = UDim2.new(0, size, 0, size),
        Position           = UDim2.new(math.random(), 0, 1, 20),
        BackgroundColor3   = th.Accent,
        BackgroundTransparency = 0.6 + math.random() * 0.3,
        BorderSizePixel    = 0,
        Parent             = parent,
    })
    corner(p, size)
    themed(p, "Accent")
    local duration = math.random(60, 140) / 10
    local xDrift   = (math.random() - 0.5) * 0.1
    tween(p, duration, {
        Position             = UDim2.new(math.clamp(p.Position.X.Scale + xDrift, 0, 1), 0, 0, -20),
        BackgroundTransparency = 1,
    }, Enum.EasingStyle.Linear)
    task.delay(duration, function() if p then p:Destroy() end end)
end

local function startParticleField(parent)
    ParticleLayer = new("Frame", {
        Name             = "Particles",
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex           = 0,
        Parent           = parent,
    })
    task.spawn(function()
        while ParticleLayer and ParticleLayer.Parent do
            task.wait(0.35)
            if #Particles < 40 and not Aquafield._hidden then
                spawnParticle(ParticleLayer)
            end
        end
    end)
end

