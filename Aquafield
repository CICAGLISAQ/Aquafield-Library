-- EXTRA: DESTROY / CLEANUP
--------------------------------------------------------------------------------
function Aquafield:Destroy()
    if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
    table.clear(self._windows)
    table.clear(self._themed)
    table.clear(self.Flags)
end

