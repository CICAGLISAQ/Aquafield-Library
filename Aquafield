local NotifHolder
function Aquafield:Notify(opts)
    opts = opts or {}
    if not NotifHolder then
        NotifHolder = create("Frame", {
            Name = "Notifications",
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -16, 1, -16),
            Size = UDim2.fromOffset(300, 600),
            BackgroundTransparency = 1,
            Parent = ScreenGui,
            ZIndex = 100,
        })
        create("UIListLayout", {
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            HorizontalAlignment = Enum.HorizontalAlignment.Right,
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = NotifHolder,
        })
    end
    local theme = Aquafield.Themes[Aquafield.CurrentTheme]
    local card = create("Frame", {
        BackgroundColor3 = theme.Surface,
        BackgroundTransparency = 0.05,
        BorderSizePixel = 0,
        Size = UDim2.fromOffset(300, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = NotifHolder,
        ZIndex = 101,
    })
    corner(card, 10)
    stroke(card, theme.Accent, 1, 0.3)
    create("UIPadding", {
        PaddingTop = UDim.new(0,10), PaddingBottom = UDim.new(0,10),
        PaddingLeft = UDim.new(0,12), PaddingRight = UDim.new(0,12),
        Parent = card,
    })
    create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16),
        Font = Enum.Font.GothamBold, Text = opts.Title or "Notification",
        TextSize = 13, TextColor3 = theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = card,
    })
    create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.fromOffset(0, 20),
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Font = Enum.Font.Gotham, Text = opts.Content or "",
        TextSize = 12, TextColor3 = theme.SubText, TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = card,
    })
    card.Size = UDim2.fromOffset(0, 0)
    spring(card, 0.4, { Size = UDim2.fromOffset(300, card.AbsoluteSize.Y) })
    task.delay(opts.Duration or 4, function()
        tween(card, 0.4, { BackgroundTransparency = 1 })
        for _, c in ipairs(card:GetDescendants()) do
            if c:IsA("TextLabel") then tween(c, 0.4, { TextTransparency = 1 }) end
            if c:IsA("UIStroke") then tween(c, 0.4, { Transparency = 1 }) end
        end
        task.wait(0.45)
        card:Destroy()
    end)
end

return Aquafield
