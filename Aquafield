function Aquafield:CreateWindow(opts)
    opts = opts or {}
    local themeName = opts.Theme
    if themeName and Themes[themeName] then
        Aquafield.ThemeName = themeName
        Aquafield.Theme = Themes[themeName]
    end
    local th = Aquafield.Theme

    local Window = {
        Tabs = {},
        Cfg = opts.ConfigurationSaving or {},
    }

    local function build()
        if not opts.DisableAquafieldPrompts then
            showLoadingScreen(opts.LoadingTitle or "Aquafield",
                              opts.LoadingSubtitle or "Interface Suite", th)
        end
        task.wait(opts.DisableAquafieldPrompts and 0 or 1.2)

        local Main = new("Frame", {
            Name = "Main",
            Size = UDim2.new(0, 560, 0, 380),
            Position = UDim2.new(0.5, -280, 0.5, -190),
            BackgroundColor3 = th.Background, BorderSizePixel = 0,
            Parent = ScreenGui, ClipsDescendants = true,
        })
        corner(Main, 12); stroke(Main, th.Border, 1, 0.2); themed(Main, "Background")

        -- Topbar
        local Top = new("Frame", {
            Size = UDim2.new(1, 0, 0, 38),
            BackgroundColor3 = th.Topbar, BorderSizePixel = 0, Parent = Main,
        })
        themed(Top, "Topbar")
        new("Frame", { Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, 0),
            BackgroundColor3 = th.Border, BorderSizePixel = 0, Parent = Top })
        makeDraggable(Main, Top)

        local titleX = 16
        if opts.Icon and opts.Icon ~= 0 then
            local iconImg = typeof(opts.Icon) == "number"
                and ("rbxassetid://" .. tostring(opts.Icon))
                or tostring(opts.Icon)
            local ic = new("ImageLabel", {
                Image = iconImg, Size = UDim2.new(0, 18, 0, 18),
                Position = UDim2.new(0, 14, 0.5, -9),
                BackgroundTransparency = 1, ImageColor3 = th.Accent, Parent = Top,
            })
            themed(ic, "Accent", "image")
            titleX = 40
        end

        local Title = new("TextLabel", {
            Text = opts.Name or "Aquafield",
            Font = Enum.Font.GothamBold, TextSize = 14,
            TextColor3 = th.Text, BackgroundTransparency = 1,
            Position = UDim2.new(0, titleX, 0, 0),
            Size = UDim2.new(0.7, 0, 1, 0),
            TextXAlignment = Enum.TextXAlignment.Left, Parent = Top,
        })
        themed(Title, "Text", "text")

        local function topBtn(icon, xOff)
            local b = new("TextButton", {
                Text = icon, Font = Enum.Font.GothamBold, TextSize = 16,
                TextColor3 = th.SubText, BackgroundTransparency = 1,
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, xOff, 0.5, 0),
                Size = UDim2.new(0, 24, 0, 24), Parent = Top,
            })
            themed(b, "SubText", "text")
            return b
        end
        local CloseBtn = topBtn("✕", -10)
        local MinBtn   = topBtn("—", -40)

        -- Sidebar
        local Side = new("Frame", {
            Size = UDim2.new(0, 140, 1, -38),
            Position = UDim2.new(0, 0, 0, 38),
            BackgroundColor3 = th.Sidebar, BorderSizePixel = 0, Parent = Main,
        })
        themed(Side, "Sidebar")
        new("Frame", { Size = UDim2.new(0, 1, 1, 0), Position = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = th.Border, BorderSizePixel = 0, Parent = Side })

        local SideList = new("Frame", {
            Size = UDim2.new(1, 0, 1, -110),
            BackgroundTransparency = 1, Parent = Side,
        })
        pad(SideList, 8)
        new("UIListLayout", {
            Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder, Parent = SideList,
        })

        -- Theme switcher (Aquafield bonus)
        local ThemeBox = new("Frame", {
            AnchorPoint = Vector2.new(0, 1),
            Position = UDim2.new(0, 0, 1, -8),
            Size = UDim2.new(1, 0, 0, 90),
            BackgroundTransparency = 1, Parent = Side,
        })
        pad(ThemeBox, 8)
        new("UIListLayout", { Padding = UDim.new(0, 6), Parent = ThemeBox })
        new("TextLabel", {
            Text = "THEME", Font = Enum.Font.GothamBold, TextSize = 10,
            TextColor3 = th.SubText, BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 12),
            TextXAlignment = Enum.TextXAlignment.Left, Parent = ThemeBox,
        })
        local swatchRow = new("Frame", {
            Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, Parent = ThemeBox,
        })
        new("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal,
            Padding = UDim.new(0, 6), Parent = swatchRow })
        for _, name in ipairs({"Crimson", "MatrixGreen", "Ocean"}) do
            local sw = new("TextButton", {
                Text = "", BackgroundColor3 = Themes[name].Accent,
                Size = UDim2.new(0, 22, 0, 22), BorderSizePixel = 0, Parent = swatchRow,
            })
            corner(sw, 11); stroke(sw, Color3.fromRGB(255,255,255), 1, 0.8)
            sw.MouseButton1Click:Connect(function() Aquafield:SetTheme(name) end)
        end

        local Container = new("Frame", {
            Size = UDim2.new(1, -140, 1, -38),
            Position = UDim2.new(0, 140, 0, 38),
            BackgroundTransparency = 1, Parent = Main,
        })

        Window._Main = Main
        Window._SideList = SideList
        Window._Container = Container

        -- minimize / close
        local minimized = false
        function Window:Toggle()
            minimized = not minimized
            tween(Main, 0.25, { Size = minimized and UDim2.new(0, 560, 0, 38)
                                              or UDim2.new(0, 560, 0, 380) })
        end
        MinBtn.MouseButton1Click:Connect(function() Window:Toggle() end)
        CloseBtn.MouseButton1Click:Connect(function()
            saveConfig(Window)
            tween(Main, 0.25, { Size = UDim2.new(0, 0, 0, 0),
                                Position = UDim2.new(0.5, 0, 0.5, 0),
                                BackgroundTransparency = 1 })
            task.wait(0.3); ScreenGui:Destroy()
        end)

        Main.Size = UDim2.new(0, 0, 0, 0)
        Main.Position = UDim2.new(0.5, 0, 0.5, 0)
        tween(Main, 0.35, { Size = UDim2.new(0, 560, 0, 380),
                            Position = UDim2.new(0.5, -280, 0.5, -190) },
                           Enum.EasingStyle.Back)
        Window._ready = true
    end

    -- Key system gating
    if opts.KeySystem then
        runKeySystem(opts.KeySettings or {}, th, function() task.spawn(build) end)
    else
        task.spawn(build)
    end

    -- block until ready so CreateTab works synchronously
    local timeout = 0
    while not Window._ready and timeout < 30 do task.wait(0.05); timeout = timeout + 0.05 end

    ----------------------------------------------------------------
    -- TABS
    ----------------------------------------------------------------
    local activeTab
    function Window:CreateTab(name, icon)
        local Tab = { Name = name }
        local SideList = Window._SideList
        local Container = Window._Container
        local th = Aquafield.Theme

        local Btn = new("TextButton", {
            Text = "", Size = UDim2.new(1, 0, 0, 30),
            BackgroundColor3 = th.Element, BackgroundTransparency = 1,
            AutoButtonColor = false, Parent = SideList,
        })
        corner(Btn, 6); themed(Btn, "Element")

        local labelX = 10
        if icon and icon ~= 0 then
            local iconImg = typeof(icon) == "number"
                and ("rbxassetid://" .. tostring(icon))
                or tostring(icon)
            local img = new("ImageLabel", {
                Image = iconImg, Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.new(0, 8, 0.5, -8),
                BackgroundTransparency = 1, ImageColor3 = th.SubText, Parent = Btn,
            })
            themed(img, "SubText", "image")
            labelX = 30
        end
        local lbl = new("TextLabel", {
            Text = name, Font = Enum.Font.GothamMedium, TextSize = 13,
            TextColor3 = th.SubText, BackgroundTransparency = 1,
            Position = UDim2.new(0, labelX, 0, 0),
            Size = UDim2.new(1, -labelX - 4, 1, 0),
            TextXAlignment = Enum.TextXAlignment.Left, Parent = Btn,
        })
        themed(lbl, "SubText", "text")

        local Page = new("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
            BorderSizePixel = 0, ScrollBarThickness = 3,
            ScrollBarImageColor3 = th.Accent,
            CanvasSize = UDim2.new(0,0,0,0), Visible = false, Parent = Container,
        })
        pad(Page, 12)
        local list = new("UIListLayout", {
            Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder, Parent = Page,
        })
        list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Page.CanvasSize = UDim2.new(0, 0, 0, list.AbsoluteContentSize.Y + 24)
        end)

        local function select()
            if activeTab then
                activeTab.Page.Visible = false
                tween(activeTab.Btn, 0.15, { BackgroundTransparency = 1 })
                activeTab.Lbl.TextColor3 = Aquafield.Theme.SubText
            end
            activeTab = { Page = Page, Btn = Btn, Lbl = lbl }
            Page.Visible = true
            tween(Btn, 0.15, { BackgroundTransparency = 0 })
            lbl.TextColor3 = Aquafield.Theme.Text
        end
        Btn.MouseButton1Click:Connect(select)
        if not activeTab then select() end

        local function baseElement(h)
            local th = Aquafield.Theme
            local f = new("Frame", {
                Size = UDim2.new(1, 0, 0, h or 36),
                BackgroundColor3 = th.Element, BorderSizePixel = 0, Parent = Page,
            })
            corner(f, 6); stroke(f, th.Border, 1, 0.6); themed(f, "Element")
            return f
        end

