            tabContent.Visible = true
            stroke(tabBtn, th.TabActive, 1.5, 0.2)
            
            -- Animate content entrance
            tabContent.Size = UDim2.new(1, 0, 0, tabContentLayout.AbsoluteContentSize.Y + 16)
            
            win._activeTab = tabData
        end)
        
