        Text = config.LoadingSubtitle or "",
        TextColor3 = theme.Window.SubTextColor,
        TextSize = 14,
        Parent = loadingFrame,
    })
    
    -- Loading bar
    local loadingBarContainer = self:Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(35, 35, 45),
        BorderSizePixel = 0,
        Size = UDim2.new(0, 200, 0, 4),
        Position = UDim2.new(0.5, -100, 0.56, 0),
        Parent = loadingFrame,
    })
    
    local loadingBarCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 2),
        Parent = loadingBarContainer,
    })
    
    local loadingBar = self:Create("Frame", {
        BackgroundColor3 = theme.Window.AccentColor,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 1, 0),
        Parent = loadingBarContainer,
    })
    
    local loadingBarFillCorner = self:Create("UICorner", {
        CornerRadius = UDim.new(0, 2),
        Parent = loadingBar,
    })
    
    -- Animate loading
    self:TweenObject(loadingBar, {Size = UDim2.new(1, 0, 1, 0)}, TweenInfo.new(1.5, Enum.EasingStyle.Quad))
    
    task.delay(1.8, function()
        self:TweenObject(loadingFrame, {BackgroundTransparency = 1}, TweenInfo.new(0.4))
        self:TweenObject(loadingTitle, {TextTransparency = 1}, TweenInfo.new(0.3))
        self:TweenObject(loadingSubtitle, {TextTransparency = 1}, TweenInfo.new(0.3))
        self:TweenObject(loadingBarContainer, {BackgroundTransparency = 1}, TweenInfo.new(0.3))
        self:TweenObject(loadingBar, {BackgroundTransparency = 1}, TweenInfo.new(0.3))
        
        task.delay(0.5, function()
            loadingFrame:Destroy()
        end)
    end)
    
    -- Make window draggable
    self:MakeDraggable(mainFrame, topbar)
    
    -- Tabs container
    local tabsContainer = self:Create("Frame", {
        Name = "TabsContainer",
        BackgroundColor3 = theme.Tab.BackgroundColor,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 160, 1, -40),
        Position = UDim2.new(0, 0, 0, 40),
        Parent = mainFrame,
    })
    
    -- Tabs list
    local tabsList = self:Create("ScrollingFrame", {
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -10, 1, -10),
        Position = UDim2.new(0, 5, 0, 5),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 0,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Parent = tabsContainer,
    })
    
    -- UIListLayout for tabs
    local tabsLayout = self:Create("UIListLayout", {
        Padding = UDim.new(0, 4),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = tabsList,
    })
    
    -- Pages container
    local pagesContainer = self:Create("Frame", {
        Name = "PagesContainer",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -170, 1, -50),
        Position = UDim2.new(0, 165, 0, 45),
        Parent = mainFrame,
    })
    
    -- Window object
    local Window = {
        ScreenGui = screenGui,
        MainFrame = mainFrame,
        Topbar = topbar,
        TabsContainer = tabsContainer,
        TabsList = tabsList,
        PagesContainer = pagesContainer,
        Tabs = {},
        Theme = theme,
        ThemeName = config.Theme or "Default",
        Config = config,
        SavedData = savedData,
        ConfigSave = configSave,
        UIKeybind = config.ToggleUIKeybind or "K",
        IsVisible = false,
        LoadingScreen = loadingFrame,
        ShowText = config.ShowText or "ShadowField",
        
        -- Toggle visibility
        ToggleUI = function(self)
            self.IsVisible = not self.IsVisible
            if self.IsVisible then
                mainFrame.Visible = true
                self:TweenObject(mainFrame, {
                    ImageTransparency = 0.3,
                    BackgroundTransparency = 0,
                }, TweenInfo.new(0.3))
            else
                self:TweenObject(mainFrame, {
                    ImageTransparency = 1,
                    BackgroundTransparency = 1,
                }, TweenInfo.new(0.3))
                task.delay(0.3, function()
                    mainFrame.Visible = false
                end)
            end
        end,
        
        -- Create tab
        CreateTab = function(self, tabConfig)
            return ShadowField:CreateTab(self, tabConfig)
        end,
        
        -- Notify
        Notify = function(self, notificationConfig)
            notificationConfig.Theme = self.ThemeName
            return ShadowField:ShowNotification(notificationConfig, pagesContainer.Parent.Parent)
        end,
        
        -- Destroy
        Destroy = function(self)
            screenGui:Destroy()
            ActiveWindows[self] = nil
        end,
    }
    
    -- Hide window initially
    mainFrame.Visible = false
    mainFrame.ImageTransparency = 1
    mainFrame.BackgroundTransparency = 1
    
    -- Keybind toggle
    local keybindConnection
    keybindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode[Window.UIKeybind] then
            Window:ToggleUI()
        end
    end)
    
    table.insert(UIConnections, keybindConnection)
    
    -- Store window reference
    ActiveWindows[Window] = true
    table.insert(ActiveWindows, Window)
    
    task.spawn(function()
        -- Wait for loading animation
        task.wait(2.5)
        -- Show window after loading if ShowText feature
        -- (Mobile support: tapping show text toggles)
    end)
    
    return Window
end

